      var url='https://translate.google.com/translate_tts?ie=UTF-8&client=tw-ob&tl='+TTS_LANG+'&q='+encodeURIComponent(chunk)+(attempt>1?('&r='+Date.now()):'');
      var a=new Audio(); try{a.referrerPolicy='no-referrer';}catch(e){} a.src=url; curAudio=a;
