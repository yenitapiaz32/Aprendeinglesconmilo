function renderDentalBar(){
  const bar=document.getElementById('dentalBar');bar.innerHTML='';
  if(profile.career!=='dentistry') return;
  DENTAL_ACADEMY.forEach((d,i)=>{
    const btn=document.createElement('button');btn.className=i===curDental?'active':'';
    btn.innerHTML=d.emoji+'<span class="sub">'+d.code.replace('D-','')+'</span>';
    btn.onclick=()=>{curDental=i;store.set('curDental',i);renderDentalBar();renderDental();};
    bar.appendChild(btn);
  });
}
