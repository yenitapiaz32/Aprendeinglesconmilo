A2:{
  cando:"I can talk about the past, make plans, and have simple conversations about daily life in French.",
  tenses:[
    {n:"Passé composé (past tense)",form:"avoir/être (present) + past participle",use:"Completed past actions. Most verbs use avoir; ~17 verbs of motion + reflexives use être.",ex:["J'ai mangé une pizza. | I ate a pizza.","Elle est allée au parc. | She went to the park.","Nous avons regardé un film. | We watched a film.","Il est arrivé tard. | He arrived late.","Tu as acheté du pain? | Did you buy bread?"]},
    {n:"Aller + infinitif (near future)",form:"vais/vas/va/allons/allez/vont + infinitif",use:"Plans and intentions — equivalent to 'going to'.",ex:["Je vais étudier ce soir. | I'm going to study tonight.","Elle va t'appeler. | She's going to call you.","Nous allons voyager en juillet. | We're going to travel in July.","Qu'est-ce que tu vas faire? | What are you going to do?","Il va pleuvoir. | It's going to rain."]},
    {n:"Pouvoir & vouloir + infinitif",form:"peux/peut/pouvons/peuvent · veux/veut/voulons/veulent",use:"Modal verbs: can/want to.",ex:["Je peux parler français. | I can speak French.","Tu peux m'aider? | Can you help me?","Je veux apprendre plus. | I want to learn more.","Elle veut un café. | She wants a coffee.","On peut venir. | We can come."]}
