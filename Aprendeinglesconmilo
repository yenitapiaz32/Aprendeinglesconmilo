    try{
      speechSynthesis.cancel(); if(speechSynthesis.resume)speechSynthesis.resume();
      var u=new SpeechSynthesisUtterance(chunk); u.lang=TTS_LOCALE[TTS_LANG]||'en-US'; u.rate=slow?0.5:0.92;
