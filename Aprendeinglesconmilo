      a.addEventListener('playing',function(){ started=true; try{if(slow)a.playbackRate=0.55;}catch(e){} });
      a.addEventListener('ended',fin);
      function gfail(){ if(finished||started||token.cancel)return; if(attempt<2){ setTimeout(tryGoogle,250); } else { browser(); } }
      a.addEventListener('error',gfail);
      var p=a.play(); if(p&&p.catch) p.catch(gfail);
      setTimeout(function(){ if(!finished && !started && (!a.currentTime || a.currentTime===0)) gfail(); }, attempt<2?1800:3000);
