}
function orderPick(i,btn){ orderBuilt.push(btn.textContent); btn.disabled=true; btn.style.opacity=.4; document.getElementById('orderBuilt').innerHTML=orderBuilt.join(' '); }
function orderCheck(){
  const ok=orderBuilt.join(' ')===orderTarget.join(' ');
