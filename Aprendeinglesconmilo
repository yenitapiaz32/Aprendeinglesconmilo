let orderTarget=[],orderBuilt=[];
function sentencePool(){
  const d=DATA[curLevel]||DATA.A1;let s=[];
  d.tenses.forEach(t=>t.ex.forEach(e=>{const en=enOnly(e);if(en.split(' ').length>=3&&en.split(' ').length<=8)s.push(en);}));
  d.grammar.forEach(g=>g.ex.forEach(e=>{const en=enOnly(e);if(en.split(' ').length>=3&&en.split(' ').length<=8)s.push(en);}));
  return s.length?s:['I live in Colombia.'];
}
function startOrder(){
  const pool=sentencePool();const sentence=pool[Math.floor(Math.random()*pool.length)].replace(/[.?!]$/,'');
  orderTarget=sentence.split(' ');orderBuilt=[];
  renderOrder(shuffle(orderTarget.slice()));
}
function renderOrder(bank){
