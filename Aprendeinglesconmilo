  tenses:[
    {n:"Subjuntivo imperfeito",form:"-AR: falasse/-asses/-asse/-ássemos/-assem · -ER/-IR: comesse/-esses/-esse/-êssemos/-essem",use:"Si clauses type 2 & 3; after past wishes/doubt.",ex:["Se tivesse tempo, estudaria mais. | If I had time, I would study more.","Queria que você viesse. | I wanted you to come.","Se tivesse sabido, teria ligado. | If I had known, I would have called.","Como se fosse fácil. | As if it were easy.","Tomara que pudesse ficar. | I wish I could stay."]},
