let fcDeck=[],fcI=0,fcFlip=false;
function initFlash(L){
  const d=DATA[L];fcDeck=[];
  d.vocab.forEach(v=>fcDeck.push([v.w,v.es+(v.syn?(' · syn: '+v.syn):''),'vocabulario']));
  d.tenses.forEach(t=>{const p=String(t.ex[0]).split('|');fcDeck.push([p[0].trim(),(p[1]?p[1].trim()+' — ':'')+t.n,'tiempo verbal']);});
  d.idioms.forEach(i=>fcDeck.push([i[0],i[1],'modismo']));
  d.grammar.forEach(g=>{const p=String(g.ex[0]).split('|');fcDeck.push([p[0].trim(),(p[1]?p[1].trim()+' — ':'')+g.t,'gramática']);});
  fcDeck=shuffle(fcDeck);fcI=0;fcFlip=false;
  const host=document.getElementById('flashHost');
  host.innerHTML='<p class="note">Todo lo del nivel en tarjetas (inglés → significado). Toca para voltear. '+fcDeck.length+' tarjetas.</p>'
   +'<div class="fc" id="fcCard" onclick="fcFlipCard()"><div class="fci">'
   +'<div class="fcf fc-front"><div class="fc-w" id="fcFront"></div><div class="fc-h">Toca para ver el significado</div></div>'
   +'<div class="fcf fc-back"><div class="fc-w" id="fcBack" style="font-size:1.05rem"></div><div class="fc-h" id="fcTag"></div></div>'
   +'</div></div>'
   +'<div class="fc-nav"><button class="btn" onclick="fcPrev()">←</button><span id="fcCount" style="font-weight:700;color:var(--muted)"></span><button class="btn primary" onclick="fcNext()">Siguiente →</button></div>'
   +'<div class="fc-nav" style="margin-top:8px;"><button class="btn" onclick="speak(fcDeck[fcI][0])">🔊 Oír</button><button class="btn" onclick="fcShuffle()">🔀 Mezclar</button></div>'
   +(isDone(L,'flash')?'<p style="text-align:center;color:var(--green);font-weight:700;margin-top:10px;">✓ Lección completada</p>':'<button class="btn green markbtn" style="display:block;width:100%;margin-top:10px;" onclick="markDone(\''+L+'\',\'flash\')">✓ Terminé de repasar</button>');
  fcRender();
}
function fcRender(){if(!fcDeck.length)return;const c=fcDeck[fcI];document.getElementById('fcFront').innerHTML='<div style="margin-bottom:4px;">'+iconHTML(c[0]+' '+c[1],'2.6rem')+'</div>'+c[0];document.getElementById('fcBack').textContent=c[1];document.getElementById('fcTag').textContent=c[2];document.getElementById('fcCount').textContent=(fcI+1)+' / '+fcDeck.length;document.getElementById('fcCard').classList.toggle('flip',fcFlip);}
function fcFlipCard(){fcFlip=!fcFlip;fcRender();}
function fcNext(){fcFlip=false;fcI=(fcI+1)%fcDeck.length;fcRender();}
function fcPrev(){fcFlip=false;fcI=(fcI-1+fcDeck.length)%fcDeck.length;fcRender();}
function fcShuffle(){fcDeck=shuffle(fcDeck);fcI=0;fcFlip=false;fcRender();}

