    {t:"Questions (three ways)",form:"Intonation? · Est-ce que...? · Inversion",ex:["Tu parles français? | Do you speak French? (intonation)","Est-ce que tu parles français? | Do you speak French? (est-ce que)","Parles-tu français? | Do you speak French? (inversion)","Où habites-tu? | Where do you live?","Comment tu t'appelles? | What's your name?"]},
    {t:"Adjective agreement",form:"Add -e for feminine, -s for plural, -es for fem. plural",ex:["un grand café | a large coffee","une grande maison | a large house","un ami sympa | a nice friend","une amie sympa | a nice (female) friend","des amis sympas | nice friends"]}
