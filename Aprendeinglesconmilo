/* convierte una palabra inglesa en una secuencia de visemes (aproximado pero útil) */
function wordToVisemes(word){
  var s=String(word).toLowerCase().replace(/[^a-z]/g,'');
  var out=[],i=0;
  function push(v){out.push(v);}
  while(i<s.length){
    var two=s.substr(i,2);
    if(two==='gh'){i+=2;continue;} /* casi siempre muda (though, light) */
    if(two==='ck'){push('K');i+=2;continue;}
    if(two==='kn'&&i===0){push('TD');i+=2;continue;} /* know, knee */
    if(two==='wr'&&i===0){push('R');i+=2;continue;} /* write */
    if(two==='th'){push('TH');i+=2;continue;}
    if(two==='sh'||two==='ch'||two==='tc'){push('SH');i+=2;continue;}
    if(two==='ph'){push('F');i+=2;continue;}
    if(two==='wh'){push('W');i+=2;continue;}
    if(two==='ng'){push('K');i+=2;continue;}
    if(two==='qu'){push('K');push('W');i+=2;continue;}
    if(two==='oo'){push('UW');i+=2;continue;}
    if(two==='ee'||two==='ea'||two==='ie'){push('IY');i+=2;continue;}
    if(two==='ou'||two==='ow'||two==='oa'){push('OW');i+=2;continue;}
    if(two==='ai'||two==='ay'){push('EH');push('IY');i+=2;continue;}
    var c=s[i];
    /* 'e' final muda */
    if(c==='e' && i===s.length-1 && s.length>2){ i++; continue; }
    switch(c){
      case 'a':push('AE');break;
      case 'e':push('EH');break;
      case 'i':push('IH');break;
      case 'o':push('OW');break;
      case 'u':push('UH');break;
      case 'y':push('IH');break;
      case 'b':case 'p':case 'm':push('M');break;
      case 'f':case 'v':push('F');break;
      case 'w':push('W');break;
      case 'r':push('R');break;
      case 'l':push('L');break;
      case 't':case 'd':case 'n':push('TD');break;
      case 's':case 'z':push('S');break;
      case 'c':push((s[i+1]==='e'||s[i+1]==='i'||s[i+1]==='y')?'S':'K');break;
      case 'g':push((s[i+1]==='e'||s[i+1]==='i'||s[i+1]==='y')?'SH':'K');break;
      case 'j':push('SH');break;
      case 'k':case 'q':case 'x':push('K');break;
      case 'h':push('AA');break;
      default:break;
    }
    i++;
  }
  if(!out.length)out.push('AA');
  return out;
}
