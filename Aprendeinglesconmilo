function renderFill(d){
  let h='<p class="note">Escribe la palabra que falta y pulsa Revisar. (Mín. 6 ejercicios)</p><div class="skillbox">';
  d.fill.forEach((f,i)=>{h+='<p>'+(i+1)+'. '+f[0].replace('___','<input class="fill" id="fill'+i+'" autocomplete="off">')+'</p>';});
  h+='<button class="btn primary" onclick="checkFill('+d.fill.length+')">Revisar</button> <span id="fillScore" style="font-weight:700;margin-left:8px;"></span></div>';
  window.__fillAns=d.fill.map(f=>f[1]);
  return h;
}
function checkFill(n){
  let ok=0;
  for(let i=0;i<n;i++){const inp=document.getElementById('fill'+i);const val=norm(inp.value);const ans=norm(window.__fillAns[i]);if(val===ans){inp.classList.add('ok');inp.classList.remove('no');ok++;}else{inp.classList.add('no');inp.classList.remove('ok');inp.title='Respuesta: '+window.__fillAns[i];}}
  document.getElementById('fillScore').textContent=ok+' / '+n+' correctas'+(ok<n?' (pasa el cursor por las rojas para ver la respuesta)':' 🎉');
  if(ok>=Math.ceil(n*0.7)) markDone(curLevel,'fill');
}

/* ===== QUIZ ENGINE ===== */
let qState=null;
function startQuiz(hostId,items,isTest){qState={host:hostId,items:shuffle(items),i:0,score:0,isTest:isTest,mode:isTest?'test':'quiz'};renderQ();}

/* ===== REPETICIÓN ESPACIADA ===== */
let review=store.get('review',[]);
function pushReview(it){
  if(it.type!=='mc') return;
  if(review.some(r=>r.q===it.q)) return;
  review.push({q:it.q,a:it.a,opts:it.opts,box:0});
  store.set('review',review);
}
function updateReview(it,good){
  const r=review.find(x=>x.q===it.q); if(!r) return;
  if(good){r.box=(r.box||0)+1; if(r.box>=2){review=review.filter(x=>x.q!==it.q);}}
  else{r.box=0;}
  store.set('review',review);
}
function startRepaso(){
  const items=shuffle(review).slice(0,10).map(r=>({type:'mc',q:r.q,a:r.a,opts:shuffle(r.opts.slice())}));
  qState={host:'quizHost',items:items,i:0,score:0,isTest:false,mode:'repaso'};renderQ();
}
function renderRepaso(){
  const el=document.getElementById('homeContent');
  el.innerHTML='<button class="backbtn" onclick="renderHome()">← Volver</button>'
    +'<div class="card"><h2>🔁 Repaso inteligente</h2><p class="note">Milo te muestra justo lo que has fallado antes. Acierta cada una 2 veces para dominarla y que deje de aparecer.</p><div id="quizHost"></div></div>';
  startRepaso();
}
function renderQ(){
  const host=document.getElementById(qState.host);if(!host)return;
  if(qState.i>=qState.items.length){finishQuiz(host);return;}
  const it=qState.items[qState.i];
  let h='<div style="font-size:.8rem;color:var(--muted);margin-bottom:6px;">Pregunta '+(qState.i+1)+' de '+qState.items.length+' · Aciertos: '+qState.score+'</div>';
  h+='<div style="text-align:center;margin-bottom:6px;">'+iconHTML((it.a+' '+it.q).replace('___',it.a),'2.8rem')+'</div>';
  h+='<div class="q">'+it.q.replace('___','<span style="color:var(--blue)">_____</span>')+'</div>';
  if(it.type==='mc'){h+='<div class="opts">';it.opts.forEach(o=>h+='<button class="opt" onclick="ansQ(this,\''+o.replace(/'/g,"\\'")+'\')">'+o+'</button>');h+='</div>';}
  else{h+='<input class="fill" id="qfill" autocomplete="off" style="width:200px;"> <button class="btn primary" onclick="ansFillQ()">OK</button>';}
  h+='<div class="feedback" id="fb"></div>';
  host.innerHTML=h;
}
function ansQ(btn,choice){
  const it=qState.items[qState.i];const fb=document.getElementById('fb');
  document.querySelectorAll('#'+qState.host+' .opt').forEach(b=>{b.disabled=true;if(b.textContent===it.a)b.classList.add('correct');});
  const good=choice===it.a;
  if(good){qState.score++;beep('good');fb.innerHTML='<span style="color:var(--green)">✓ ¡Correcto!</span>';}
  else{btn.classList.add('wrong');beep('bad');fb.innerHTML='<span style="color:var(--red)">✗ Era: '+it.a+'</span>';}
  if(qState.mode==='placement'&&it.lvl){qState.byLevel[it.lvl].t++;if(good)qState.byLevel[it.lvl].c++;}
  if((qState.mode==='quiz'||qState.mode==='test'||qState.mode==='dentalquiz')&&!good)pushReview(it);
  if(qState.mode==='repaso')updateReview(it,good);
  setTimeout(()=>{qState.i++;renderQ();},1400);
}
function ansFillQ(){
  const it=qState.items[qState.i];const fb=document.getElementById('fb');const val=norm(document.getElementById('qfill').value);
  const good=val===norm(it.a);
  if(good){qState.score++;beep('good');fb.innerHTML='<span style="color:var(--green)">✓ ¡Correcto!</span>';}
  else{beep('bad');fb.innerHTML='<span style="color:var(--red)">✗ Era: '+it.a+'</span>';}
  if(qState.mode==='placement'&&it.lvl){qState.byLevel[it.lvl].t++;if(good)qState.byLevel[it.lvl].c++;}
  setTimeout(()=>{qState.i++;renderQ();},1500);
}
function finishQuiz(host){
  if(qState.mode==='placement'){return finishPlacement(host);}
  if(qState.mode==='dentalquiz'){
    addXP(qState.score*5);confetti();beep('win');
    let h='<div class="scorebig">'+qState.score+' / '+qState.items.length+'</div><p style="text-align:center;">🦷 ¡Buen trabajo, doctora! +'+(qState.score*5)+' XP</p>';
    h+='<div style="text-align:center;"><button class="btn primary" onclick="renderDental()">Volver al módulo</button></div>';
    host.innerHTML=h;return;
  }
  if(qState.mode==='repaso'){
    addXP(qState.score*3);
    let h='<div class="scorebig">'+qState.score+' / '+qState.items.length+'</div>';
    h+='<p style="text-align:center;">Te quedan <b>'+review.length+'</b> tarjetas por dominar.</p>';
    h+='<div style="text-align:center;">'+(review.length?'<button class="btn primary" onclick="renderRepaso()">Seguir repasando</button> ':'')+'<button class="btn" onclick="renderHome()">Volver al inicio</button></div>';
    host.innerHTML=h;return;
  }
  const pct=Math.round(qState.score/qState.items.length*100);
  let h='<div class="scorebig">'+qState.score+' / '+qState.items.length+' ('+pct+'%)</div>';
  if(!qState.isTest && pct>=70) markDone(curLevel,'quiz');
  if(qState.isTest){
    if(pct>=80){
      markDone(curLevel,'test');confetti();beep('win');
      const idx=LEVELS.indexOf(curLevel);const next=LEVELS[idx+1];
      if(next && !unlocked.includes(next)){unlocked.push(next);store.set('unlocked',unlocked);renderLevelBar();}
      h+='<p style="text-align:center;color:var(--green);font-weight:700;">🎉 ¡Aprobaste! '+(next?('Nivel '+next+' desbloqueado.'):'¡Completaste todos los niveles!')+'</p>';
    } else { h+='<p style="text-align:center;color:var(--red);font-weight:700;">Necesitas 80% para desbloquear el siguiente nivel. Repasa y vuelve a intentar 💪</p>'; }
    h+='<div style="text-align:center;"><button class="btn primary" onclick="startTest(\''+curLevel+'\')">Reintentar examen</button></div>';
  } else {
    let msg=pct>=90?'🏆 ¡Dominado!':pct>=70?'💪 ¡Muy bien!':'📈 Repasa y reintenta.';
    h+='<p style="text-align:center;">'+msg+'</p><div style="text-align:center;"><button class="btn primary" onclick="reQuiz()">Otro intento</button></div>';
  }
  host.innerHTML=h;
}
function reQuiz(){startQuiz('quizHost',DATA[curLevel].quiz.map(q=>({type:'mc',q:q[0],a:q[1],opts:shuffle([...new Set([q[1]].concat(q[2]))])})),false);}

/* ===== EXAMEN DE NIVELACIÓN ===== */
function renderPlacement(){
  const el=document.getElementById('homeContent');
  el.innerHTML='<button class="backbtn" onclick="renderHome()">← Volver</button>'
    +'<div class="card"><h2>📊 Examen de nivelación</h2><p class="note">15 preguntas de dificultad creciente (A1 → C1). Al terminar te diremos en qué nivel empezar y desbloquearemos todo hasta ahí. Si no sabes una, elige tu mejor opción.</p><div id="quizHost"></div></div>';
  startPlacement();
}
function startPlacement(){
  let items=[];
  LEVELS.forEach(L=>{shuffle(DATA[L].quiz).slice(0,5).forEach(q=>items.push({type:'mc',q:q[0],a:q[1],opts:shuffle([...new Set([q[1]].concat(q[2]))]),lvl:L}));});
  items.sort((a,b)=>LEVELS.indexOf(a.lvl)-LEVELS.indexOf(b.lvl));
  qState={host:'quizHost',items:items,i:0,score:0,isTest:false,mode:'placement',byLevel:{}};
  LEVELS.forEach(L=>qState.byLevel[L]={c:0,t:0});
  renderQ();
}
function finishPlacement(host){
  let rec='A1';
  for(const L of LEVELS){const b=qState.byLevel[L];if(b.t>0 && b.c/b.t>=0.6){rec=L;}else break;}
  const idx=LEVELS.indexOf(rec);
  for(let i=0;i<=idx;i++){if(!unlocked.includes(LEVELS[i]))unlocked.push(LEVELS[i]);}
  store.set('unlocked',unlocked);curLevel=rec;store.set('curLevel',rec);
  confetti();beep('win');renderLevelBar();
  let h='<div class="scorebig">🎯 Tu nivel: '+rec+' · '+meta[rec].n+'</div>';
  h+='<p style="text-align:center;">Desbloqueamos desde <b>A1</b> hasta <b>'+rec+'</b>. Empieza donde te sientas cómoda.</p>';
  h+='<p class="note" style="text-align:center;">Detalle por nivel: '+LEVELS.map(L=>L+' '+qState.byLevel[L].c+'/'+qState.byLevel[L].t).join(' · ')+'</p>';
  h+='<button class="cta" style="max-width:260px;margin:12px auto 0;" onclick="openLevel(\''+rec+'\')">Empezar en '+rec+' →</button>';
  host.innerHTML=h;
}

