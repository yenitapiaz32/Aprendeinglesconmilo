  grammar:[
    {t:"Gender & articles: o/a, um/uma",form:"Masculine: o/um · Feminine: a/uma. All nouns have gender.",ex:["o livro (m) | the book","a mesa (f) | the table","um carro | a car","uma casa | a house","o/a estudante | the student"]},
    {t:"Plural: os/as",form:"Add -s (vowels) or change final consonant.",ex:["os livros | the books","as mesas | the tables","os carros | the cars","as casas | the houses","os estudantes | the students"]},
    {t:"Subject pronouns",form:"eu, você/tu, ele/ela, nós, vocês, eles/elas",ex:["Eu sou americano/a. | I am American.","Você fala inglês. | You speak English.","Ele/Ela é simpático/a. | He/She is nice.","Nós moramos aqui. | We live here.","Vocês são do Texas. | You all are from Texas."]},
    {t:"Gostar de (to like)",form:"gosto/gosta/gostam de + noun/infinitive",ex:["Eu gosto de café. | I like coffee.","Você gosta de filmes? | Do you like movies?","Ela gosta de dançar. | She likes to dance.","Gostamos de viagens. | We like trips.","Não gosto de frio. | I don't like the cold."]},
    {t:"Negation & questions",form:"Não + verb · Question: Verb + subject? or rising intonation",ex:["Não falo chinês. | I don't speak Chinese.","Você fala português? | Do you speak Portuguese?","Não tenho carro. | I don't have a car.","Onde você mora? | Where do you live?","Como você se chama? | What's your name?"]}
  ],
  vocab:[
    {w:"a família",es:"the family",ex:["Tenho uma família grande. | I have a big family.","Minha família mora no Texas. | My family lives in Texas.","A família é importante. | Family is important.","Você tem família aqui? | Do you have family here?","Somos uma família feliz. | We are a happy family."]},
    {w:"o amigo / a amiga",es:"friend",ex:["Ela é minha melhor amiga. | She is my best friend.","Tenho muitos amigos. | I have many friends.","Meu amigo é engraçado. | My friend is funny.","É um bom amigo. | He's a good friend.","Os amigos se ajudam. | Friends help each other."]},
    {w:"a casa",es:"house / home",ex:["Minha casa é pequena. | My house is small.","A casa é bonita. | The house is pretty.","Limpo minha casa. | I clean my house.","Onde fica a sua casa? | Where is your house?","Bem-vindo à minha casa! | Welcome to my home!"]},
    {w:"a água",es:"water",ex:["Bebo água todo dia. | I drink water every day.","Pode me dar água? | Can you give me water?","A água está fria. | The water is cold.","A água é saudável. | Water is healthy.","Preciso de água. | I need water."]},
    {w:"a comida",es:"food",ex:["Adoro comida brasileira. | I love Brazilian food.","A comida está boa. | The food is good.","Compramos comida. | We buy food.","A comida italiana é saborosa. | Italian food is delicious.","Você gosta de comida apimentada? | Do you like spicy food?"]}
  ],
  idioms:[["Tudo bem?","Everything OK? / How are you?","Oi! Tudo bem? — Tudo ótimo! | Hi! How are you? — Everything great!"],["Com licença","Excuse me","Com licença, pode me ajudar? | Excuse me, can you help me?"],["Com certeza!","Of course! / Certainly!","Você pode vir? Com certeza! | Can you come? Of course!"],["Sinto muito","I'm sorry","Sinto muito pelo atraso. | I'm sorry for the delay."],["Que legal!","How cool! / That's great!","Fui ao Brasil! — Que legal! | I went to Brazil! — How cool!"]],
  dialog:[
    {t:"👋 Greetings",lines:[["A","Oi! Como você se chama?","Hi! What's your name?"],["B","Me chamo Alex. E você?","My name is Alex. And you?"],["A","Sou Sam. Muito prazer.","I'm Sam. Nice to meet you."],["B","Igualmente! De onde você é?","Likewise! Where are you from?"],["A","Sou dos Estados Unidos.","I'm from the United States."]]},
    {t:"☕ At the café",lines:[["A","Oi, por favor, um café.","Hi, a coffee please."],["B","Grande ou pequeno?","Large or small?"],["A","Grande, por favor. Quanto é?","Large, please. How much is it?"],["B","São três reais.","It's three reais."],["A","Aqui está. Obrigado/a!","Here you go. Thank you!"]]}
  ],
  reading:{text:["Oi! Me chamo Alex. Sou dos Estados Unidos. Tenho uma família pequena: minha mãe, meu pai e minha irmã. Moramos em uma casa com jardim. Eu gosto de futebol e música. Todo dia vou ao trabalho de metrô. Meu melhor amigo se chama Lucas. Ele é muito engraçado."],tr:"Hi! My name is Alex. I'm from the United States. I have a small family: my mom, my dad, and my sister. We live in a house with a garden. I like football and music. Every day I go to work by subway. My best friend's name is Lucas. He's very funny.",q:["De onde é Alex? | Where is Alex from?","Como é sua família? | What is his family like?","Como ele vai ao trabalho? | How does he go to work?","Do que ele gosta? | What does he like?","Como se chama o amigo dele? | What's his friend's name?"]},
  listening:[["Portuguese for beginners","https://www.youtube.com/results?search_query=portuguese+for+beginners+a1+slow"],["Brazilian Portuguese basics","https://www.youtube.com/results?search_query=brazilian+portuguese+basics+vocabulary"],["Easy Portuguese greetings","https://www.youtube.com/results?search_query=portuguese+greetings+basic+conversation"],["Easy Portuguese (YouTube)","https://www.youtube.com/@EasyPortuguese"],["Portuguese numbers and colors","https://www.youtube.com/results?search_query=portuguese+numbers+colors+beginner"]],
  writing:["Write 3 sentences about yourself (name, country, family) in Portuguese.","Describe your home using ser/estar.","Write 3 things you have (tenho...) and 3 things you like (gosto de...).","Describe a friend in 3 sentences.","Make a list of 5 things you do every day."],
  speaking:["Introduce yourself in Portuguese (30 seconds, record yourself).","Count to 20 in Portuguese.","Describe 5 objects in your room using 'isto é um/uma...'.","Say 5 things you like and 5 you don't like.","Describe your family (5 sentences)."],
  quiz:[["Eu ___ dos Estados Unidos.","sou",["estou","são","é"]],["O café ___ frio.","está",["é","são","estou"]],["Ela ___ inteligente. (permanent)","é",["está","são","sou"]],["___ (eu) um cachorro.","Tenho",["Tem","Têm","Temos"]],["Eu gosto ___ café.","de",["da","para","com"]],["Eles ___ muito.","viajam",["viaja","viajo","viajam"]]],
  fill:[["Eu ___ (falar) português.","falo"],["Ela ___ (ser) do Brasil.","é"],["A casa ___ (estar) limpa.","está"],["Nós ___ (comer) pizza.","comemos"],["Onde ___ (morar) você?","mora"],["Eu ___ (ter) um gato.","tenho"]]
},
A2:{
  cando:"I can talk about the past, make plans, and have basic conversations about daily life in Portuguese.",
  tenses:[
    {n:"Pretérito perfeito (past simple)",form:"-AR: falei/falou/falamos/falaram · -ER: comi/comeu/comemos/comeram · -IR: fui/foi/fomos/foram",use:"Completed actions in the past.",ex:["Ontem fui ao parque. | Yesterday I went to the park.","Ela comprou um vestido. | She bought a dress.","Comemos juntos na sexta. | We ate together on Friday.","Onde você foi nas férias? | Where did you go on vacation?","Ele chegou tarde. | He arrived late."]},
    {n:"Ir + infinitivo (near future)",form:"vou/vai/vamos/vão + infinitive",use:"Plans and intentions — just like 'going to'.",ex:["Vou estudar esta noite. | I'm going to study tonight.","Ela vai te ligar. | She's going to call you.","Vamos viajar em julho. | We're going to travel in July.","O que você vai fazer? | What are you going to do?","Vai chover. | It's going to rain."]},
    {n:"Poder & querer + infinitivo",form:"posso/pode/podemos/podem · quero/quer/queremos/querem",use:"Modal verbs: can/want to.",ex:["Posso falar português. | I can speak Portuguese.","Você pode me ajudar? | Can you help me?","Quero aprender mais. | I want to learn more.","Não posso vir hoje. | I can't come today.","Ela quer um café. | She wants a coffee."]}
  ],
  grammar:[
    {t:"Verbos reflexivos",form:"me/se/nos + verb",ex:["Me chamo Alex. | My name is Alex.","Como você se chama? | What's your name?","Ela se levanta às 7. | She gets up at 7.","Nos levantamos cedo. | We get up early.","Se chama Carlos. | His name is Carlos."]},
    {t:"Comparativos",form:"mais...do que · menos...do que · tão...quanto",ex:["Esta cidade é maior do que a minha. | This city is bigger than mine.","O café é mais barato aqui. | Coffee is cheaper here.","Ela é tão alta quanto eu. | She is as tall as me.","É o mais popular. | It's the most popular.","Ele fala melhor do que antes. | He speaks better than before."]},
    {t:"Advérbios de frequência",form:"sempre, normalmente, às vezes, raramente, nunca",ex:["Sempre tomo café da manhã em casa. | I always have breakfast at home.","Normalmente caminho ao trabalho. | I usually walk to work.","Às vezes como fora. | I sometimes eat out.","Raramente assisto TV. | I rarely watch TV.","Nunca fumo. | I never smoke."]}
  ],
  vocab:[
    {w:"ontem",es:"yesterday",ex:["Vi ela ontem. | I saw her yesterday.","Ontem foi segunda. | Yesterday was Monday.","Nos conhecemos ontem. | We met yesterday.","Choveu ontem. | It rained yesterday.","Ela me ligou ontem. | She called me yesterday."]},
    {w:"o fim de semana",es:"the weekend",ex:["Descanso nos fins de semana. | I rest on weekends.","Bom fim de semana! | Have a nice weekend!","O que você fez no fim de semana? | What did you do this weekend?","Viajamos todo fim de semana. | We travel every weekend.","O fim de semana foi ótimo. | The weekend was great."]},
    {w:"precisar",es:"to need",ex:["Preciso de ajuda. | I need help.","Ela precisa de água. | She needs water.","Você precisa de algo? | Do you need anything?","Precisamos conversar. | We need to talk.","Eles precisam de mais tempo. | They need more time."]},
    {w:"ocupado/a",es:"busy",ex:["Estou muito ocupado/a hoje. | I'm very busy today.","Ela está muito ocupada. | She's very busy.","Você está ocupado/a agora? | Are you busy now?","Foi uma semana ocupada. | It was a busy week.","Ele está ocupado no trabalho. | He's busy at work."]}
  ],
  idioms:[["Que saudade!","I miss it so much! / How I've missed...!","Que saudade de você! | I've missed you so much!"],["Que ótimo!","That's great! / Wonderful!","Passei! — Que ótimo! | I passed! — That's great!"],["Deixa pra lá","Forget it / Never mind","Não se preocupe, deixa pra lá. | Don't worry, forget it."],["Tá bom","OK / Alright (informal)","Pode me ajudar? — Tá bom! | Can you help me? — OK!"],["Mais ou menos","So-so / more or less","Tá bem? — Mais ou menos. | Are you OK? — So-so."]],
  dialog:[
    {t:"🍽️ At the restaurant",lines:[["Garçom","Já vão pedir?","Are you ready to order?"],["You","Sim, quero o frango, por favor.","Yes, I'll have the chicken, please."],["Garçom","Para beber?","Something to drink?"],["You","Só água, obrigado/a.","Just water, thanks."],["Garçom","Ótimo. Já vou trazer.","Great. I'll bring it right away."]]}
  ],
  reading:{text:["No fim de semana passado fui ao mercado com meu amigo Tom. No sábado compramos frutas frescas e legumes. À tarde, cozinhamos juntos em casa. Comemos uma feijoada deliciosa. No domingo fomos à praia. Estava muito calor mas nos divertimos muito. No próximo fim de semana vamos visitar outra cidade."],tr:"Last weekend I went to the market with my friend Tom. On Saturday we bought fresh fruit and vegetables. In the afternoon, we cooked together at home. We ate a delicious feijoada. On Sunday we went to the beach. It was very hot but we had a great time. Next weekend we're going to visit another city.",q:["Com quem foi ao mercado? | Who did he go to the market with?","O que compraram no sábado? | What did they buy on Saturday?","O que cozinharam? | What did they cook?","Onde foram no domingo? | Where did they go on Sunday?","O que vão fazer no próximo fim de semana? | What will they do next weekend?"]},
  listening:[["Portuguese A2 conversations","https://www.youtube.com/results?search_query=portuguese+a2+conversation+practice"],["Brazilian past tense","https://www.youtube.com/results?search_query=brazilian+portuguese+past+tense+lesson"],["Easy Portuguese A2","https://www.youtube.com/results?search_query=easy+portuguese+a2+listening"],["Brazilian daily life","https://www.youtube.com/results?search_query=brazilian+portuguese+daily+life+vocabulary"],["Portuguese stories for beginners","https://www.youtube.com/results?search_query=portuguese+comprehensible+input+beginner"]],
  writing:["Write what you did last weekend (5 sentences, past tense).","Write your plans for next week (ir + infinitivo).","Compare two cities using comparativos.","Describe your daily routine.","Write about a trip you took (5 sentences)."],
  speaking:["Tell what you did yesterday — 1 minute.","Describe a family member in 5 sentences.","Make plans: 'Esse fim de semana vou...'.","Compare two things out loud using mais/menos/tão.","Say 5 things you can and can't do."],
  quiz:[["Ontem eu ___ ao parque.","fui",["foi","ia","irei"]],["Ela ___ um vestido. (pretérito)","comprou",["compra","comprará","comprando"]],["Esta cidade é ___ do que a minha.","maior",["mais grande","grande","mais maior"]],["___ (eu) estudar esta noite.","Vou",["Vai","Vamos","Vão"]],["Você ___ me ajudar?","pode",["pode","poder","posso"]],["Nunca ___ tarde. (eu, chegar)","chego",["chegou","chegará","chegado"]]],
  fill:[["Ontem eu ___ (ir) ao mercado.","fui"],["Ela ___ (levantar-se) às 7.","se levanta"],["Vou ___ (estudar) mais tarde.","estudar"],["Esta cidade é ___ (grande) do que a minha.","maior"],["Você ___ (poder) vir amanhã?","pode"],["Nós ___ (comer) pizza ontem.","comemos"]]
},
B1:{
  cando:"I can discuss past experiences, give opinions, and start using the subjunctive in Portuguese.",
  tenses:[
    {n:"Pretérito imperfeito (imperfect)",form:"-AR: falava/-avas/-ava/-ávamos/-avam · -ER/-IR: comia/-ias/-ia/-íamos/-iam",use:"Past habits, background description, ongoing past states.",ex:["Quando era criança, brincava no parque. | When I was a child, I played in the park.","Ela estudava todo dia. | She used to study every day.","Estava chovendo quando cheguei. | It was raining when I arrived.","Morávamos em Chicago. | We were living in Chicago.","O que você fazia aos domingos? | What did you use to do on Sundays?"]},
    {n:"Futuro do presente (simple future)",form:"falar-ei/-ás/-á/-emos/-ão (same pattern all verbs)",use:"Future plans and predictions.",ex:["Amanhã falarei com meu chefe. | Tomorrow I'll talk to my boss.","Ela viajará para o Brasil. | She will travel to Brazil.","Quando você voltará? | When will you return?","Estudaremos juntos. | We will study together.","Haverá muita gente. | There will be many people."]},
    {n:"Ter + particípio (present perfect)",form:"tenho/tem/temos/têm + past participle",use:"Recent experiences or actions with present relevance.",ex:["Tenho comido bem. | I have been eating well.","Você tem estudado? | Have you been studying?","Ela tem trabalhado muito. | She has been working a lot.","Temos viajado bastante. | We have been traveling a lot.","Eles têm melhorado. | They have been improving."]}
  ],
  grammar:[
    {t:"Por vs Para",form:"para = purpose/destination/deadline · por = cause/exchange/duration",ex:["Estudo para aprender. | I study in order to learn.","Este presente é para você. | This gift is for you.","Comprei por dez reais. | I bought it for ten reais.","Caminhei por uma hora. | I walked for an hour.","Obrigado pela ajuda. | Thanks for the help."]},
    {t:"Subjuntivo: introdução",form:"quero que + subj · espero que + subj · é importante que + subj",ex:["Quero que você venha. | I want you to come.","Espero que chegue a tempo. | I hope you arrive on time.","É importante que você estude. | It's important that you study.","Não quero que vá embora. | I don't want you to leave.","Tomara que faça bom tempo. | Hopefully the weather will be good."]},
    {t:"False friends (PT vs EN)",form:"words that look similar but differ",ex:["polvo = octopus (not powder!) | polvo = polvo","borracha = rubber eraser (not 'drunk'!) | borracha = goma de borrar","presunçoso = presumptuous (not ham!) | presuntoso = presumido","esquisito = weird (not 'exquisite'!) | raro/extraño","policia = police (noun, f.) | policía"]}
  ],
  vocab:[
    {w:"melhorar",es:"to improve",syn:"progredir, avançar",ex:["Quero melhorar meu português. | I want to improve my Portuguese.","Ela melhorou muito. | She improved a lot.","A prática melhora tudo. | Practice improves everything.","Como posso melhorar? | How can I improve?","Sua pronúncia melhorou. | Your pronunciation has improved."]},
    {w:"na verdade",es:"actually / in reality",syn:"de fato, realmente",ex:["Na verdade, não sei. | Actually, I don't know.","Na verdade é mais fácil. | It's actually easier.","Na verdade, você tem razão. | Actually, you're right.","Não fiz, na verdade. | I actually didn't do it.","Na verdade, é verdade. | Actually, that's true."]},
    {w:"no entanto",es:"however / nevertheless",syn:"porém, todavia",ex:["É difícil; no entanto, tentarei. | It's hard; however, I'll try.","No entanto, os preços subiram. | However, prices went up.","No entanto, continuamos. | Nevertheless, we continued.","É caro; no entanto, vale a pena. | It's expensive; however, it's worth it.","Concordo. No entanto... | I agree. However..."]},
    {w:"ter vontade de",es:"to feel like / to want to",syn:"querer, desejar",ex:["Tenho vontade de viajar. | I feel like traveling.","Você tem vontade de comer algo? | Do you feel like eating something?","Não tenho vontade de estudar. | I don't feel like studying.","Ela tem vontade de aprender. | She wants to learn.","Tenho muita vontade de te ver. | I really want to see you."]}
  ],
  idioms:[["Cada macaco no seu galho","Each to their own / Mind your own business","Cada macaco no seu galho. | Each to their own."],["Em cima da hora","Last minute / just in time","Chegou em cima da hora. | He arrived last minute."],["Pisar em ovos","To tread carefully / walk on eggshells","Preciso pisar em ovos com ela. | I need to tread carefully with her."],["Bater papo","To chat / have a conversation","A gente fica batendo papo. | We just chat away."],["Deu certo","It worked out","O plano deu certo! | The plan worked out!"]],
  dialog:[
    {t:"✈️ At the airport",lines:[["Agente","Bom dia. Seu passaporte, por favor.","Good morning. Your passport, please."],["You","Aqui está.","Here it is."],["Agente","Vai despachar bagagem?","Are you checking any bags?"],["You","Só uma mala.","Just one suitcase."],["Agente","Tudo bem. Seu portão é o B12. Boa viagem!","All good. Your gate is B12. Have a great trip!"]]}
  ],
  reading:{text:["Há cerca de um ano que estou aprendendo português. No começo, tudo parecia muito difícil, e quase desisti. No entanto, continuei praticando e agora consigo ter conversas básicas. A chave foi não ter medo de cometer erros. Se você quer aprender um idioma novo, precisa ser paciente consigo mesmo e continuar, mesmo quando é difícil."],tr:"I've been learning Portuguese for about a year. At first, everything seemed very difficult and I almost gave up. However, I kept practicing and now I can have basic conversations. The key was not being afraid of making mistakes. If you want to learn a new language, you need to be patient with yourself and keep going, even when it's hard.",q:["Há quanto tempo está aprendendo português? | How long has he been learning Portuguese?","Como parecia no começo? | How did it seem at first?","Por que quase desistiu? | Why did he almost give up?","O que consegue fazer agora? | What can he do now?","Qual foi a chave? | What was the key?"]},
  listening:[["Dreaming Portuguese intermediate","https://www.youtube.com/results?search_query=dreaming+portuguese+intermediate"],["Brazilian Portuguese B1","https://www.youtube.com/results?search_query=brazilian+portuguese+b1+listening+practice"],["Imperfeito vs perfeito","https://www.youtube.com/results?search_query=imperfeito+vs+perfeito+portuguese+lesson"],["Brazilian TV shows","https://www.youtube.com/results?search_query=brazilian+portuguese+tv+series+subtitles"],["Português com Letícia","https://www.youtube.com/results?search_query=portugues+com+leticia"]],
  writing:["Write about a childhood habit using the imperfeito.","Give your opinion on a topic using no entanto/porque.","Describe a future plan (futuro do presente).","Write about a recent experience (ter + participio).","Use the subjunctive: 'Espero que...', 'Quero que...'."],
  speaking:["Talk for 2 minutes about a trip or experience.","Give your opinion on a topic (acho que, na minha opinião).","Talk about what you used to do as a child (imperfeito).","Describe what you've been doing recently.","Practice: 'Quero que...' sentences with subjunctive."],
  quiz:[["Quando era criança, ___ no parque. (brincar)","brincava",["brinquei","brincará","brincou"]],["Este presente é ___ você.","para",["por","a","de"]],["Quero que você ___ (vir).","venha",["vem","virá","veio"]],["Na verdade, ___ razão.","você tem",["tem","tenho","tens"]],["Amanhã eu ___ com ela. (falar)","falarei",["falei","falaria","falo"]],["Tenho ___ de viajar.","vontade",["vontades","vontades de","de vontade"]]],
  fill:[["Quando era criança, ___ (morar) em Boston.","morava"],["Amanhã ___ (falar / eu) com ela.","falarei"],["Quero que você ___ (vir).","venha"],["Este presente é ___ (for) você.","para"],["Na verdade, ___ (estar) certo.","está"],["Tenho ___ (vontade) de aprender.","vontade"]]
},
B2:{
  cando:"I can express complex ideas, discuss hypotheticals, and understand Brazilian TV and music.",
  tenses:[
    {n:"Condicional (conditional)",form:"-ia/-ias/-ia/-íamos/-iam (all verbs)",use:"Hypotheticals; polite requests.",ex:["Gostaria de visitar o Brasil. | I would like to visit Brazil.","Você poderia me ajudar? | Could you help me?","Se tivesse dinheiro, viajaria. | If I had money, I would travel.","Seria ótimo. | That would be great.","O que você faria? | What would you do?"]},
    {n:"Subjuntivo presente (full use)",form:"falar→fale, comer→coma, ir→vá",use:"Emotion, doubt, desire, impersonal expressions.",ex:["Espero que você chegue logo. | I hope you arrive soon.","Duvido que seja verdade. | I doubt it's true.","É necessário que você estude. | It's necessary that you study.","Procuro um apartamento que seja barato. | I'm looking for a cheap apartment.","Quando você chegar, me ligue. | When you arrive, call me."]}
  ],
  grammar:[
    {t:"Voz passiva (passive voice)",form:"ser + past participle (+ por + agent)",ex:["O livro foi escrito por Machado de Assis. | The book was written by Machado de Assis.","A casa foi construída em 1990. | The house was built in 1990.","Os preços foram aumentados. | The prices were raised.","O contrato foi assinado. | The contract was signed.","Por quem foi pintado? | By whom was it painted?"]},
    {t:"Discurso indireto (reported speech)",form:"disse que + imperfeito/condicional",ex:["Ela disse que estava cansada. | She said she was tired.","Ele me disse que viria. | He told me he would come.","Perguntou onde eu morava. | She asked where I lived.","Disse que tinha terminado. | He said he had finished.","Afirmou que era verdade. | She claimed it was true."]},
    {t:"Orações relativas",form:"que (people/things), quem (people), onde (places), cujo/a (whose)",ex:["O homem que ligou é meu chefe. | The man who called is my boss.","A cidade onde nasci. | The city where I was born.","A pessoa com quem falei. | The person with whom I spoke.","O livro cujo autor é famoso. | The book whose author is famous.","O dia em que nos conhecemos. | The day on which we met."]}
  ],
  vocab:[
    {w:"apesar de",es:"despite / in spite of",syn:"embora, mesmo que",ex:["Apesar da chuva, saímos. | Despite the rain, we went out.","Apesar de tudo, sigo em frente. | In spite of everything, I carry on.","Apesar de ser difícil, consegui. | Despite being hard, I managed.","Apesar do frio, corri. | Despite the cold, I ran.","Apesar de seus erros, ganhou. | Despite his mistakes, he won."]},
    {w:"vale a pena",es:"it's worth it",syn:"merece a pena",ex:["Vale a pena tentar. | It's worth trying.","Vale a pena ir? | Is it worth going?","Não vale a pena se preocupar. | It's not worth worrying.","Sempre vale a pena aprender. | It's always worth learning.","A espera valeu a pena. | The wait was worth it."]},
    {w:"se destacar",es:"to stand out",syn:"sobressair, brilhar",ex:["Ela se destaca no trabalho. | She stands out at work.","O que faz você se destacar? | What makes you stand out?","Ele se destacou entre os candidatos. | He stood out among the candidates.","Seu trabalho se destaca pela qualidade. | Her work stands out for its quality.","Quero me destacar em português. | I want to excel in Portuguese."]}
  ],
  idioms:[["Virar a mesa","To turn the tables","Ele virou a mesa na negociação. | He turned the tables in the negotiation."],["Não é bem assim","It's not quite like that","Não é bem assim. | It's not quite like that."],["Bater na mesma tecla","To keep harping on the same thing","Ele fica batendo na mesma tecla. | He keeps harping on the same thing."],["Dar o fora","To get out / to leave","Dei o fora daquela empresa. | I got out of that company."]],
  reading:{text:["Mudar-se para uma nova cidade pode ser um ponto de virada na sua vida, embora raramente seja fácil. Quando cheguei, não conhecia ninguém e tinha dificuldade em me orientar. Apesar das dificuldades, o que mais me ajudou foi me forçar a falar com estranhos. No entanto, no começo era muito desconfortável. Olhando para trás, esses momentos desconfortáveis eram exatamente o que eu precisava para crescer."],tr:"Moving to a new city can be a turning point in your life, although it's rarely easy. When I arrived, I didn't know anyone and had trouble getting around. Despite the difficulties, what helped me most was forcing myself to talk to strangers. However, at first it was very uncomfortable. Looking back, those uncomfortable moments were exactly what I needed to grow.",q:["O que pode ser mudar de cidade? | What can moving to a new city be?","Como se sentia ao chegar? | How did she feel when she arrived?","O que mais a ajudou? | What helped her the most?","Como era falar com estranhos no começo? | How was it to talk to strangers at first?","O que eram os momentos desconfortáveis? | What were those uncomfortable moments?"]},
