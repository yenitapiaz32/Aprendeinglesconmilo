  const p=totalPct();const hour=new Date().getHours();const greet=hour<12?'Buenos días':hour<19?'Buenas tardes':'Buenas noches';
  const ul=userLevel();
  const phrase=miloSays();
  let h='<div class="hero"><div class="hero-row">'
    +'<div class="ring" style="--p:'+p+'"><div class="inner"><div><div class="pct">'+p+'%</div><div class="lbl">completado</div></div></div></div>'
    +'<div style="flex:1;min-width:160px;"><h2>'+greet+', '+profile.name+' 👋</h2><p>Inglés <b>'+curLevel+'</b></p>'
    +'<div style="background:rgba(255,255,255,.18);border-radius:12px;padding:8px 10px;margin-top:8px;">'
      +'<div style="display:flex;justify-content:space-between;font-size:.82rem;font-weight:700;"><span>⭐ Nivel '+ul.lvl+'</span><span>'+ul.into+'/'+ul.need+' XP</span></div>'
      +'<div style="background:rgba(255,255,255,.25);border-radius:99px;height:9px;margin-top:5px;overflow:hidden;"><div style="background:#ffd166;height:100%;width:'+Math.round(ul.into/ul.need*100)+'%;border-radius:99px;"></div></div></div>'
    +'<button class="cta" style="margin-top:10px;max-width:220px;" onclick="goTab(\'levels\')">▶ Continuar aprendiendo</button></div>'
    +'<div style="display:flex;flex-direction:column;align-items:center;"><div class="bubble">'+phrase+'</div>'+ILLUS+'</div>'
    +'</div></div>';
  h+='<div class="stats">'
    +'<div class="stat anim-in"><div class="n">🔥 '+streak.count+'</div><div class="l">días de racha</div></div>'
    +'<div class="stat anim-in" style="animation-delay:.05s"><div class="n">⭐ '+ul.lvl+'</div><div class="l">nivel usuario</div></div>'
    +'<div class="stat anim-in" style="animation-delay:.1s"><div class="n">⚡ '+xp+'</div><div class="l">puntos XP</div></div>'
    +'<div class="stat anim-in" style="animation-delay:.15s"><div class="n">'+unlocked.length+'/5</div><div class="l">niveles</div></div>'
    +'</div>';
  h+='<button class="btn" style="width:100%;margin-bottom:10px;" onclick="startTour()">❓ Cómo usar la app (tour)</button>';
  h+='<button class="btn" style="width:100%;margin-bottom:6px;" onclick="testAudio()">🔊 Probar sonido</button>';
  h+='<div id="audioDiag" class="note" style="display:none;background:#0b1f4d;color:#fff;padding:10px;border-radius:10px;margin-bottom:10px;font-size:13px;"></div>';
  h+='<button class="btn primary" style="width:100%;margin-bottom:10px;" onclick="showLangSelector()">🌍 Idioma: '+((typeof TARGET_INFO!=='undefined'&&TARGET_INFO[curTarget])?TARGET_INFO[curTarget].flag+' '+TARGET_INFO[curTarget].name:'🇺🇸 Inglés')+' · Cambiar idioma</button>';
  h+='<div class="card"><h2>👤 Mi cuenta</h2><div id="authBox"></div></div>';
  h+='<div class="card"><h2>💾 Mi progreso (respaldo)</h2><p class="note">Además de la cuenta, puedes mover tu avance con un código (útil sin internet):</p><button class="btn" style="margin-bottom:6px;" onclick="exportProgress()">📋 Copiar mi código</button> <button class="btn" onclick="importProgress()">📥 Restaurar con código</button><div id="saveBox" style="display:none;margin-top:8px;"></div></div>';
  h+='<button class="cta" style="background:linear-gradient(135deg,#d97706,#f59e0b);margin-bottom:12px;" onclick="goTab(\'challenge\')">🔥 Reto diario de 3 minutos</button>';
  h+='<button class="btn primary" style="width:100%;margin-bottom:16px;font-size:.95rem;" onclick="renderPlacement()">📊 Examen de nivelación — empieza en tu nivel, no desde cero</button>';
  // Objetivo (¿por qué estudias inglés?)
  if(!profile.goal){
    h+='<div class="card" style="border:2px solid var(--blue);"><h2>🎯 ¿Por qué estudias inglés?</h2><p class="note">Elige tu objetivo y Milo personaliza tu motivación.</p><div class="pill-row">';
    GOALS.forEach(g=>{h+='<span style="cursor:pointer;" onclick="setGoal(\''+g[0]+'\')">'+g[1]+' '+g[2]+'</span>';});
    h+='</div></div>';
  } else {
    h+='<div class="card"><h2>🎯 Tu objetivo</h2><p style="font-size:1.05rem;font-weight:700;">'+goalLabel(profile.goal)+'</p><p class="note">Cada lección te acerca a tu meta. <a href="#" style="color:var(--blue)" onclick="profile.goal=\'\';store.set(\'profile\',profile);renderHome();return false;">Cambiar</a></p></div>';
  }
  // Repaso inteligente (repetición espaciada)
  if(review.length){
    h+='<div class="card" style="border:2px solid #ffd166;"><h2>🔁 Repaso inteligente</h2>'
      +'<p class="note">Milo detectó <b>'+review.length+'</b> cosa(s) que te costaron. Repásalas para que se te queden.</p>'
      +'<button class="cta" style="background:linear-gradient(135deg,#d97706,#f59e0b);" onclick="renderRepaso()">🔁 Repasar lo que fallé ('+review.length+')</button></div>';
  }
  // Meta diaria
  const dc=dailyCount();
  h+='<div class="card"><h2>🎯 Meta de hoy ('+dc+'/4)</h2><p class="note">Cada día haz al menos una práctica de cada habilidad. ¡No rompas la cadena!</p>';
  h+='<div class="progwrap"><div class="progfill" style="width:'+(dc/4*100)+'%"></div></div>';
  SK4.forEach(x=>{const done=dailyDone(x[0]);
    h+='<div class="lesson-card'+(done?' done':'')+'" onclick="goDaily()"><div class="lesson-ico">'+x[1]+'</div>'
      +'<div class="lesson-meta"><div class="t">'+x[2]+'</div><div class="d">'+(done?'✓ Hecho hoy':'Pendiente — practica '+x[3])+'</div></div>'
      +'<div class="lesson-check '+(done?'':'todo')+'">'+(done?'✓':'›')+'</div></div>';
  });
  if(dc===4) h+='<p style="text-align:center;color:var(--green);font-weight:800;margin-top:6px;">🏆 ¡Meta diaria completa! Eres imparable.</p>';
  h+='</div>';
  // niveles resumen
  h+='<div class="card"><h2>Tu camino</h2>';
  const lvlIco={A1:meta.A1.e,A2:meta.A2.e,B1:meta.B1.e,B2:meta.B2.e,C1:meta.C1.e};
  LEVELS.forEach(L=>{const lock=!unlocked.includes(L);const pc=levelPct(L);
    h+='<div class="lesson-card'+(pc===100?' done':'')+'" onclick="'+(lock?'alert(\'🔒 Bloqueado. Aprueba el examen del nivel anterior (80%+).\')':'openLevel(\''+L+'\')')+'">'
      +'<div class="lesson-ico">'+(lock?'🔒':lvlIco[L])+'</div>'
      +'<div class="lesson-meta"><div class="t">'+L+' · '+meta[L].n+'</div><div class="d">'+(lock?'Bloqueado':pc+'% completado')+'</div>'
      +'<div class="progwrap" style="margin:6px 0 0"><div class="progfill" style="width:'+pc+'%"></div></div></div>'
      +'<div class="lesson-check '+(pc===100?'':'todo')+'">'+(pc===100?'✓':'›')+'</div></div>';
  });
  h+='</div>';
  // logros
  h+='<div class="card"><h2>🏆 Logros</h2><div class="ach-row">';
  ACHS.forEach(a=>{const ok=a.ok();h+='<div class="ach'+(ok?'':' locked')+'"><div class="ico">'+a.ico+'</div><div><div class="t">'+a.t+'</div><div class="d">'+a.d+'</div></div></div>';});
  h+='</div></div>';
  // tema
  h+='<div class="card"><h2>🎨 Tema de color</h2><p class="note">Elige la paleta que más te guste. Cada una transmite algo distinto:</p><div class="chiprow" id="themeChips"></div><p class="note" id="themeWhy"></p></div>';
  el.innerHTML=h;
  const tc=document.getElementById('themeChips');const cur=store.get('theme','blue');
  Object.keys(THEMES).forEach(k=>{const sp=document.createElement('span');sp.className='chip';sp.textContent=THEMES[k].name;sp.style.cursor='pointer';if(k===cur){sp.style.color='#fff';sp.style.background=THEMES[k].blue;}sp.onclick=()=>{applyTheme(k);renderHome();};tc.appendChild(sp);});
  document.getElementById('themeWhy').textContent='💡 '+THEMES[cur].why;
  applyTheme(cur);
  try{renderAuth();}catch(e){}
  if(!store.get('tourDone',false)) setTimeout(startTour,500);
}
function saveName(){const v=document.getElementById('nameIn').value.trim();if(!v)return;profile.name=v;store.set('profile',profile);tickStreak();renderHome();}
function chooseLangOnboard(code){profile.lang=code;store.set('profile',profile);applyTarget(code);}
function chooseCareerOnboard(id){profile.career=id;if(id==='dentistry')curDental=0;store.set('profile',profile);beep('good');confetti();renderDentalBar();renderDental();renderHome();}
function chooseCareerOther(){
  var t=(document.getElementById('careerOtherIn').value||'').trim();
  if(!t){alert('Escribe el nombre de tu carrera.');return;}
  profile.career='other';profile.careerOther=t;store.set('profile',profile);
  var list=store.get('otherCareers',[]);list.push({career:t,date:new Date().toISOString()});store.set('otherCareers',list);
  beep('good');confetti();toast('¡Gracias! Anotamos: '+t);renderHome();
}
/* Vocabulario de la carrera para mostrar dentro de las lecciones */
function careerItems(){
  if(!profile.career||profile.career==='other')return [];
  if(profile.career==='dentistry'){var a=[];DENTAL_ACADEMY.forEach(function(d){d.modules.forEach(function(m){a=a.concat(m.items);});});return a;}
  var c=careerById(profile.career);if(!c||!c.modules)return [];var r=[];c.modules.forEach(function(m){r=r.concat(m.items);});return r;
}
function careerSpotlightHTML(){
  if(curTarget!=='en')return '';
  var items=careerItems(); if(!items.length||Math.random()>0.6)return '';
  var it=items[Math.floor(Math.random()*items.length)];
  var c=careerById(profile.career); var name=c?c.name:'tu carrera';
  return '<div class="skillbox" style="border:2px solid var(--amber);background:var(--card2);"><h4>🔎 Para tu carrera ('+name+')</h4><p style="margin:0;"><b>'+it[0]+'</b> '+sb(it[0])+'<br><span class="es">'+it[1]+'</span></p></div>';
}
function choosePrincipiante(){profile.onboarded=true;store.set('profile',profile);curLevel='A1';store.set('curLevel','A1');renderLevelBar();renderSub();renderContent();toast('🌱 ¡Empecemos en A1!');renderHome();}
function chooseExam(){profile.onboarded=true;store.set('profile',profile);renderPlacement();}
function openLevel(L){curLevel=L;store.set('curLevel',L);renderLevelBar();renderSub();renderContent();goTab('levels');}

/* ===== INIT ===== */
if(store.get('dark',false)){document.body.classList.add('dark');}
applyTheme(store.get('theme','blue'));
document.getElementById('darkBtn').textContent=document.body.classList.contains('dark')?'☀️':'🌙';
document.getElementById('soundBtn').textContent=soundOn?'🔔':'🔕';
if(profile.name && !profile.onboarded && (countDone()>0 || unlocked.length>1)){profile.onboarded=true;store.set('profile',profile);}
checkDailyReset();tickStreak();
renderLevelBar();renderSub();renderContent();renderPron();renderAccent();renderHome();renderDentalBar();renderDental();renderSpeak();renderChallenge();renderExtrasNav();renderExtras();renderGames();renderCollections();
if(curTarget && curTarget!=='en'){applyTarget(curTarget);}
/* Mostrar la pantalla de acceso de inmediato (oculta el contenido hasta iniciar sesión) */
try{ ensureGate(); renderGate(); }catch(e){}
/* Iniciar sesión de Supabase (login + progreso en la nube) */
try{ sbInitSession(); }catch(e){}
/* Precargar voces del navegador (para el respaldo de audio) */
if('speechSynthesis' in window){try{speechSynthesis.getVoices();speechSynthesis.onvoiceschanged=function(){speechSynthesis.getVoices();};}catch(e){}}
/* Limpiar service worker y caché viejos para que SIEMPRE cargue la última versión */
if('serviceWorker' in navigator){
  navigator.serviceWorker.getRegistrations().then(function(rs){rs.forEach(function(r){r.unregister();});}).catch(function(){});
}
if('caches' in window){ caches.keys().then(function(ks){ks.forEach(function(k){caches.delete(k);});}).catch(function(){}); }
</script>
