function beep(type){
  if(!soundOn)return;
  try{actx=actx||new (window.AudioContext||window.webkitAudioContext)();
    if(actx.state==='suspended'){actx.resume();}
    const seq=type==='good'?[660,880]:type==='win'?[523,659,784,1046]:[300,200];
    seq.forEach((f,i)=>{const o=actx.createOscillator(),g=actx.createGain();o.type='sine';o.frequency.value=f;
      const t=actx.currentTime+i*0.1;o.connect(g);g.connect(actx.destination);
      g.gain.setValueAtTime(0.0001,t);g.gain.exponentialRampToValueAtTime(0.18,t+0.02);g.gain.exponentialRampToValueAtTime(0.0001,t+0.16);
      o.start(t);o.stop(t+0.18);});
  }catch(e){}
}

