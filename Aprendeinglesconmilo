let matchSel=null,matchLeft=0;
function startMatch(){
  const d=DATA[curLevel]||DATA.A1;
  const pool=shuffle(d.vocab.slice()).slice(0,6);
  const pairs=pool.map(v=>[enOnly(v.w), v.es]);
  matchLeft=pairs.length;
  const left=shuffle(pairs.map((p,i)=>({t:p[0],i:i})));
  const right=shuffle(pairs.map((p,i)=>({t:p[1],i:i})));
  let h='<p class="note">Toca una palabra en inglés y luego su traducción.</p><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">';
  h+='<div id="mcLeft">'+left.map(x=>'<button class="opt mtile" data-i="'+x.i+'" data-side="L" onclick="matchPick(this)" style="width:100%;margin-bottom:6px;">'+x.t+'</button>').join('')+'</div>';
  h+='<div id="mcRight">'+right.map(x=>'<button class="opt mtile" data-i="'+x.i+'" data-side="R" onclick="matchPick(this)" style="width:100%;margin-bottom:6px;">'+x.t+'</button>').join('')+'</div>';
  h+='</div><div id="matchMsg" class="feedback"></div>';
  document.getElementById('gameHost').innerHTML=h;matchSel=null;
}
function matchPick(btn){
  if(btn.disabled)return;
  if(!matchSel){matchSel=btn;btn.style.borderColor='var(--blue)';return;}
  if(matchSel===btn){matchSel.style.borderColor='';matchSel=null;return;}
  if(matchSel.dataset.side===btn.dataset.side){matchSel.style.borderColor='';matchSel=btn;btn.style.borderColor='var(--blue)';return;}
  if(matchSel.dataset.i===btn.dataset.i){
    [matchSel,btn].forEach(b=>{b.disabled=true;b.classList.add('correct');b.style.borderColor='';});
    beep('good');matchLeft--;matchSel=null;
    if(matchLeft<=0){addXP(15);confetti();beep('win');document.getElementById('matchMsg').innerHTML='<span style="color:var(--green)">🎉 ¡Completado! +15 XP</span> <button class="btn" onclick="startMatch()">Otra ronda</button>';}
