<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="referrer" content="no-referrer">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<title>American English · A1–C1 · Yenifer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>
<link rel="manifest" href="manifest.webmanifest">
<meta name="theme-color" content="#2456d6">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Milo English">
<link rel="apple-touch-icon" href="icon.png">
<style>
  :root{--bg:#eef2f9;--card:#fff;--card2:#f8fafd;--ink:#1b2436;--muted:#667085;--line:#e3e8f3;--blue:#2456d6;--blue-d:#16357f;
    --red:#d92d20;--green:#15a34a;--amber:#d97706;--purple:#7c3aed;--pink:#db2777;--radius:16px;--shadow:0 4px 20px rgba(20,30,60,.08);}
  body.dark{--bg:#0f1626;--card:#1a2236;--card2:#222c44;--ink:#e8edf7;--muted:#9aa6c0;--line:#2c3650;--shadow:0 4px 22px rgba(0,0,0,.35);}
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:rgba(36,86,214,.15);}
  html{-webkit-text-size-adjust:100%;}
  body{font-family:'Nunito','Segoe UI',system-ui,-apple-system,sans-serif;background:var(--bg);background-image:radial-gradient(circle at 12% 8%,rgba(36,86,214,.06),transparent 38%),radial-gradient(circle at 88% 0%,rgba(124,58,237,.06),transparent 36%);color:var(--ink);padding-bottom:70px;line-height:1.55;}
  h1,h2,h3,.fc-w,.stat .n,.ring .pct,.hero h2{font-family:'Baloo 2','Nunito',sans-serif;letter-spacing:.2px;}
  header{background:linear-gradient(135deg,#16357f,#2456d6);color:#fff;padding:18px 16px 12px;text-align:center;}
  header h1{font-size:1.25rem;font-weight:800;}
  header p{opacity:.85;font-size:.82rem;margin-top:3px;}
  .vbar{background:#ecfdf5;border-bottom:1px solid #a7f3d0;padding:8px 14px;font-size:.8rem;text-align:center;color:#065f46;}
  nav{display:flex;flex-wrap:nowrap;overflow-x:auto;-webkit-overflow-scrolling:touch;gap:6px;padding:10px 8px;background:var(--card);box-shadow:var(--shadow);position:sticky;top:0;z-index:50;scrollbar-width:none;}
  nav::-webkit-scrollbar{display:none;}
  nav button{border:none;background:var(--card2);color:var(--ink);padding:10px 15px;border-radius:99px;cursor:pointer;font-size:.85rem;font-weight:600;white-space:nowrap;flex:0 0 auto;min-height:42px;}
  nav button.active{background:var(--blue);color:#fff;box-shadow:0 4px 12px rgba(36,86,214,.35);}
  @media(min-width:760px){nav{flex-wrap:wrap;justify-content:center;overflow-x:visible;}}
  main{max-width:880px;margin:0 auto;padding:16px 14px;}
  .tab{display:none;}.tab.active{display:block;animation:fade .25s;}
  @keyframes fade{from{opacity:0;transform:translateY(6px);}to{opacity:1;}}
  .card{background:var(--card);border-radius:22px;box-shadow:var(--shadow);padding:20px;margin-bottom:16px;}
  h2{font-size:1.25rem;margin-bottom:6px;color:var(--blue-d);}
  h3{font-size:1.02rem;margin:14px 0 6px;}
  h4{font-size:.92rem;margin:10px 0 4px;color:var(--blue-d);}
  p{margin-bottom:8px;font-size:.93rem;}
  p.note{color:var(--muted);font-size:.86rem;margin-bottom:10px;}
  .lead{font-size:.88rem;color:var(--muted);margin-bottom:14px;}
  .level-bar{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;}
  .level-bar button{flex:1;min-width:90px;border:2px solid var(--line);background:var(--card);border-radius:12px;padding:10px 6px;cursor:pointer;font-weight:800;color:var(--ink);text-align:center;position:relative;}
  .level-bar button .sub{display:block;font-size:.62rem;font-weight:500;color:var(--muted);margin-top:2px;}
  .level-bar button.active{border-color:var(--blue);background:var(--blue);color:#fff;}
  .level-bar button.active .sub{color:#dce6ff;}
  .level-bar button.locked{opacity:.55;background:#f1f3f8;cursor:not-allowed;}
  .subnav{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px;}
  .subnav button{border:1.5px solid var(--line);background:var(--card);color:var(--ink);padding:7px 12px;border-radius:99px;cursor:pointer;font-size:.82rem;font-weight:600;min-height:38px;}
  .subnav button.active{background:var(--blue);border-color:var(--blue);color:#fff;}
  .subnav button.done{border-color:var(--green);}
  @media(min-width:600px) and (max-width:1100px){main{max-width:760px;}}
  @media(max-width:600px){
    header h1{font-size:1.12rem;}main{padding:12px 10px;}.card{padding:14px 13px;}
    .level-bar button{min-width:0;flex:1 1 18%;padding:9px 2px;font-size:.95rem;}
    .level-bar button .sub{font-size:.55rem;}table{font-size:.84rem;}th,td{padding:8px 7px;}
    textarea{font-size:1rem;}
  }
  .badge{display:inline-block;font-size:.7rem;font-weight:700;padding:3px 9px;border-radius:99px;margin-right:6px;}
  .b-A1{background:#dcfce7;color:#166534;}.b-A2{background:#d1fae5;color:#065f46;}.b-B1{background:#dbeafe;color:#1e40af;}.b-B2{background:#ede9fe;color:#5b21b6;}.b-C1{background:#fce7f3;color:#9d174d;}
  ul{padding-left:20px;margin-bottom:10px;}li{font-size:.92rem;margin-bottom:7px;}
  th{border-color:var(--line)!important;}td{border-color:var(--line)!important;}
  .skillbox{border-color:var(--line)!important;background:var(--card)!important;}
  .passage{background:var(--card2)!important;border-color:var(--line)!important;}
  .tip{border-left:4px solid var(--amber);background:#fffbeb;border-radius:0 10px 10px 0;padding:10px 14px;margin-bottom:10px;font-size:.9rem;}
  .tip b{color:var(--amber);}
  .idiom{border-left:4px solid var(--purple);background:#faf7ff;border-radius:0 10px 10px 0;padding:10px 14px;margin-bottom:8px;font-size:.9rem;}
  .idiom .en{font-weight:700;color:var(--purple);}
  .syn{color:var(--pink);font-size:.83rem;font-weight:600;}
  .ex{color:var(--muted);font-size:.84rem;}
  .es{color:#7c3aed;font-size:.84rem;}
  .skillbox{border:2px solid var(--line);border-radius:18px;padding:16px;margin-bottom:13px;background:var(--card);}
  .skillbox h4{margin-top:0;color:var(--blue-d);font-size:1.05rem;font-family:'Baloo 2',sans-serif;}
  /* Ejemplos como tarjetas (más visual, menos muro de texto) */
  .skillbox ul{list-style:none;padding-left:0;margin-bottom:6px;}
  .skillbox li{background:var(--card2);border-radius:12px;padding:10px 12px;margin-bottom:8px;border-left:4px solid var(--blue);transition:transform .12s;}
  .skillbox li:hover{transform:translateX(3px);}
  .skillbox li .es{display:inline-block;margin-top:3px;}
  .vico{display:inline-grid;place-items:center;width:46px;height:46px;border-radius:14px;background:var(--card2);font-size:1.5rem;flex:0 0 auto;box-shadow:inset 0 -3px 0 rgba(0,0,0,.05);}
  .vhead{display:flex;align-items:center;gap:12px;margin-bottom:6px;}
  .vhead .vt{font-family:'Baloo 2',sans-serif;font-size:1.1rem;color:var(--blue-d);font-weight:700;}
  .exi{margin-right:4px;}
  .passage{background:#f8fafd;border-radius:10px;padding:12px 14px;font-size:.92rem;margin-bottom:10px;border:1px solid #eef2f9;}
  a.link{color:var(--red);font-weight:600;text-decoration:none;}a.link:hover{text-decoration:underline;}
  .btn{padding:10px 16px;border-radius:14px;border:2px solid var(--line);border-bottom-width:4px;background:var(--card);font-size:.9rem;cursor:pointer;font-weight:800;color:var(--ink);min-height:44px;transition:transform .05s,box-shadow .1s;}
  .btn:active{transform:translateY(2px);border-bottom-width:2px;}
  .btn.primary{background:var(--blue);border-color:rgba(0,0,0,.18);color:#fff;}
  .btn.green{background:var(--green);border-color:rgba(0,0,0,.18);color:#fff;}
  .speakbtn{background:#eef1f8;border:none;border-radius:8px;padding:5px 10px;cursor:pointer;font-size:.92rem;margin-left:4px;min-height:32px;}
  .speakbtn:active{background:#c7d6f8;}
  .speakbtn.slowbtn{margin-left:2px;font-size:.82rem;opacity:.85;}
  .speakbtn.mouthbtn{margin-left:2px;}
  .mouth-ov{position:fixed;inset:0;background:rgba(10,20,50,.55);z-index:9999;display:flex;align-items:center;justify-content:center;padding:16px;}
  .mouth-card{background:#fff;border-radius:20px;padding:18px;max-width:340px;width:100%;text-align:center;position:relative;box-shadow:0 20px 60px rgba(0,0,0,.3);}
  .mouth-x{position:absolute;top:10px;right:12px;border:none;background:#eef1f8;border-radius:50%;width:32px;height:32px;cursor:pointer;font-size:1rem;}
  .mouth-word{font-size:1.7rem;font-weight:800;color:#16357f;margin-bottom:6px;word-break:break-word;}
  .mouth-sound{margin-top:6px;color:#444;font-size:.95rem;}
  .mouth-btns{display:flex;gap:8px;justify-content:center;margin-top:10px;flex-wrap:wrap;}
  #mInner,#mLips{transition:rx .12s ease,ry .12s ease;}
  #mTongue{transition:cy .12s ease,opacity .12s ease;}
  #mTeethTop,#mTeethBot{transition:y .12s ease,opacity .12s ease;}
  .auth-gate{position:fixed;inset:0;z-index:100000;display:flex;align-items:center;justify-content:center;padding:18px;background:linear-gradient(160deg,#16357f,#2456d6 60%,#3f7be0);overflow:auto;}
  .gate-card{background:#fff;border-radius:24px;padding:26px 22px;max-width:380px;width:100%;text-align:center;box-shadow:0 24px 70px rgba(0,0,0,.35);}
  .gate-logo{font-size:3rem;line-height:1;}
  .gate-card h1{color:#16357f;margin:6px 0 2px;font-size:1.6rem;}
  .gate-card>p{color:#5a6b8c;margin:0 0 16px;font-size:.95rem;}
  .gate-tabs{display:flex;background:#eef1f8;border-radius:12px;padding:4px;margin-bottom:14px;}
  .gate-tabs button{flex:1;border:none;background:transparent;padding:9px;border-radius:9px;cursor:pointer;font-weight:700;color:#5a6b8c;font-size:.95rem;}
  .gate-tabs button.active{background:#fff;color:#16357f;box-shadow:0 2px 6px rgba(0,0,0,.08);}
  .gate-card input,.land-card input{width:100%;padding:12px;border:1px solid #ccd6ea;border-radius:12px;margin-bottom:10px;font-size:1rem;box-sizing:border-box;background:#fff;color:#1b2436;font-family:inherit;}
  .gate-card input:focus,.land-card input:focus{outline:none;border-color:#2456d6;box-shadow:0 0 0 3px rgba(36,86,214,.15);}
  .land-card .gate-btn{width:100%;}
  .gate-btn{width:100%;padding:13px;font-size:1.02rem;margin-top:2px;}
  .gate-note{color:#8493ad;font-size:.82rem;margin:14px 0 0;}
  body.gated{overflow:hidden;}
  .auth-gate{align-items:flex-start;}
  .land{max-width:980px;width:100%;margin:0 auto;}
  .land-top{position:sticky;top:0;z-index:5;display:flex;align-items:center;justify-content:space-between;gap:10px;padding:12px 16px;margin-bottom:18px;flex-wrap:wrap;background:rgba(13,31,77,.72);backdrop-filter:blur(8px);border-radius:0 0 18px 18px;}
  .land-brand{display:flex;align-items:center;gap:8px;color:#fff;font-weight:800;font-size:1.2rem;}
  .land-nav{display:flex;align-items:center;gap:4px;flex-wrap:wrap;}
  .lnav{background:transparent;border:none;color:#dde6ff;font-weight:600;font-size:.95rem;padding:8px 14px;border-radius:10px;cursor:pointer;transition:background .15s,color .15s;}
  .lnav:hover{background:rgba(255,255,255,.14);color:#fff;}
  .land-top .btn{background:#ffd166;color:#16357f;font-weight:800;border:none;}
  .land-top .btn:hover{filter:brightness(1.05);}
  @media(max-width:620px){.land-top{flex-direction:column;align-items:stretch;text-align:center;}.land-nav{justify-content:center;}}
  .land-hero{display:grid;grid-template-columns:1.1fr .9fr;gap:22px;align-items:center;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.15);border-radius:24px;padding:26px;}
  .land-hero h1{color:#fff;font-size:2rem;line-height:1.15;margin:0 0 10px;}
  .land-hero h1 .hl{color:#ffd166;}
  .land-hero .sub{color:#dde6ff;font-size:1.05rem;margin:0 0 16px;}
  .land-milo{font-size:6rem;text-align:center;line-height:1;}
  .land-card{background:#fff;border-radius:20px;padding:20px;box-shadow:0 16px 50px rgba(0,0,0,.25);}
  .land-badges{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;}
  .land-badge{background:rgba(255,255,255,.15);color:#fff;border-radius:99px;padding:6px 12px;font-size:.82rem;font-weight:700;}
  .land-sec{background:#fff;border-radius:24px;padding:26px;margin-top:20px;}
  .land-sec h2{color:#16357f;text-align:center;font-size:1.5rem;margin:0 0 6px;}
  .land-sec .lead{color:#5a6b8c;text-align:center;margin:0 auto 20px;max-width:640px;}
  .feat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;}
  .feat{background:#f6f8fe;border:1px solid #e6ecfb;border-radius:16px;padding:16px;}
  .feat .fi{font-size:1.8rem;}
  .feat h3{color:#16357f;margin:6px 0 4px;font-size:1.05rem;}
  .feat p{color:#5a6b8c;margin:0;font-size:.92rem;}
  .steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;}
  .step{text-align:center;padding:10px;}
  .step .num{width:42px;height:42px;border-radius:50%;background:#2456d6;color:#fff;font-weight:800;display:flex;align-items:center;justify-content:center;margin:0 auto 8px;font-size:1.1rem;}
  .step h3{color:#16357f;margin:0 0 4px;font-size:1rem;}
  .step p{color:#5a6b8c;margin:0;font-size:.9rem;}
  .testi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px;}
  .testi{background:#f6f8fe;border-radius:16px;padding:18px;}
  .testi .stars{color:#f5a623;margin-bottom:6px;}
  .testi p{color:#444;font-style:italic;margin:0 0 10px;}
  .testi .who{color:#16357f;font-weight:700;font-size:.9rem;}
  .plans{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px;align-items:stretch;}
  .plan{border:2px solid #e6ecfb;border-radius:20px;padding:22px;display:flex;flex-direction:column;background:#fff;}
  .plan.pop{border-color:#2456d6;box-shadow:0 12px 36px rgba(36,86,214,.18);position:relative;}
  .plan .tag{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:#2456d6;color:#fff;font-size:.75rem;font-weight:800;padding:4px 12px;border-radius:99px;}
  .plan h3{color:#16357f;margin:0 0 4px;}
  .plan .price{font-size:1.8rem;font-weight:800;color:#16357f;margin:6px 0;}
  .plan .price small{font-size:.85rem;color:#8493ad;font-weight:600;}
  .plan ul{list-style:none;padding:0;margin:10px 0 16px;text-align:left;}
  .plan li{color:#445;font-size:.9rem;padding:5px 0 5px 24px;position:relative;}
  .plan li:before{content:'🐙';position:absolute;left:0;font-size:.85rem;}
  .plan .btn{margin-top:auto;}
  .faq-item{border-bottom:1px solid #e6ecfb;padding:14px 0;}
  .faq-item h3{color:#16357f;margin:0 0 6px;font-size:1rem;}
  .faq-item p{color:#5a6b8c;margin:0;font-size:.92rem;}
  .land-cta{background:linear-gradient(135deg,#16357f,#2456d6);color:#fff;text-align:center;border-radius:24px;padding:34px 26px;margin-top:20px;}
  .land-cta h2{color:#fff;font-size:1.6rem;margin:0 0 8px;}
  .land-cta p{color:#dde6ff;margin:0 0 16px;}
  .land-foot{color:#cdd8f5;text-align:center;font-size:.85rem;padding:22px 0 8px;}
  .wa-btn{display:inline-flex;align-items:center;gap:8px;background:#25d366;color:#fff;font-weight:800;border:none;padding:14px 22px;border-radius:14px;cursor:pointer;font-size:1.05rem;text-decoration:none;}
  @media(max-width:720px){.land-hero{grid-template-columns:1fr;}.land-milo{font-size:4.4rem;}.land-hero h1{font-size:1.6rem;}}

  /* ---- Landing comercial v3: formularios, planes y legal ---- */
  .auth-wrap{max-width:430px;margin:0 auto;}
  .auth-title{font-family:'Baloo 2',sans-serif;color:#16357f;font-size:1.25rem;margin:0 0 4px;text-align:center;}
  .auth-sub{color:#5a6b8c;font-size:.9rem;text-align:center;margin:0 0 14px;}
  .auth-field{text-align:left;margin-bottom:11px;}
  .auth-field label{display:block;color:#16357f;font-size:.78rem;font-weight:800;margin:0 0 5px;}
  .auth-field input{margin-bottom:0;background:#f8fafd;border:1.5px solid #dbe5f6;}
  .auth-help{font-size:.78rem;color:#8493ad;text-align:left;margin:8px 0 0;line-height:1.35;}
  .pay-note{background:#fff7df;border:1px solid #ffe2a0;color:#6d4b00;border-radius:14px;padding:10px 12px;font-size:.84rem;line-height:1.35;margin-top:12px;}
  .legal-links{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:12px;}
  .legal-links button{border:none;background:#eef3ff;color:#16357f;border-radius:99px;padding:8px 12px;font-weight:800;cursor:pointer;}
  .legal-modal{position:fixed;inset:0;z-index:200000;background:rgba(8,18,45,.62);display:none;align-items:center;justify-content:center;padding:16px;}
  .legal-box{background:#fff;color:#1b2436;border-radius:22px;max-width:760px;width:100%;max-height:86vh;overflow:auto;padding:24px;box-shadow:0 24px 70px rgba(0,0,0,.35);}
  .legal-box h2{color:#16357f;margin:0 0 8px;font-size:1.35rem;}
  .legal-box h3{color:#16357f;margin:16px 0 6px;font-size:1.02rem;}
  .legal-box p,.legal-box li{color:#445;line-height:1.5;font-size:.93rem;}
  .legal-box ul{padding-left:20px;}
  .legal-close{float:right;border:none;background:#eef1f8;border-radius:50%;width:36px;height:36px;cursor:pointer;font-weight:800;color:#16357f;}
  .plan.trial{border-color:#15a34a;background:linear-gradient(0deg,rgba(21,163,74,.06),rgba(21,163,74,.06)),#fff;}
  .mini-legal{font-size:.78rem;color:#8493ad;line-height:1.45;text-align:center;margin-top:12px;}

  textarea{width:100%;min-height:90px;border:1.5px solid var(--line);border-radius:10px;padding:10px;font-size:.92rem;font-family:inherit;resize:vertical;background:var(--card2);color:var(--ink);}
  input.fill{border:1.5px solid var(--line);border-radius:8px;padding:6px 10px;font-size:.92rem;width:140px;font-family:inherit;background:var(--card2);color:var(--ink);}
  input.fill.ok{border-color:var(--green);background:#f0fdf4;}input.fill.no{border-color:var(--red);background:#fef2f2;}
  .pill-row{display:flex;flex-wrap:wrap;gap:8px;margin:6px 0 12px;}
  .pill-row span{background:#eef1f8;padding:7px 12px;border-radius:99px;font-size:.84rem;display:inline-flex;align-items:center;}
  .q{font-size:1.02rem;font-weight:700;margin-bottom:12px;}
  .opts{display:grid;gap:8px;}
  .opt{border:2px solid var(--line);background:var(--card);color:var(--ink);border-radius:10px;padding:11px;cursor:pointer;font-size:.96rem;text-align:left;font-weight:600;min-height:44px;}
  .opt:hover{border-color:var(--blue);}
  .opt.correct{background:#dcfce7;border-color:var(--green);animation:pop .45s ease;}.opt.wrong{background:#fee2e2;border-color:var(--red);animation:shake .4s;}
  @keyframes shake{0%,100%{transform:translateX(0);}20%{transform:translateX(-6px);}40%{transform:translateX(6px);}60%{transform:translateX(-4px);}80%{transform:translateX(4px);}}
  .feedback{animation:pop .4s;}
  .feedback{margin-top:10px;font-weight:600;min-height:22px;font-size:.9rem;}
  .scorebig{font-size:1.5rem;font-weight:800;text-align:center;margin:12px 0;}
  .fc{perspective:1000px;max-width:420px;margin:0 auto 12px;height:200px;cursor:pointer;}
  .fci{position:relative;width:100%;height:100%;transition:transform .5s;transform-style:preserve-3d;}
  .fc.flip .fci{transform:rotateY(180deg);}
  .fcf{position:absolute;inset:0;backface-visibility:hidden;-webkit-backface-visibility:hidden;border-radius:16px;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:18px;text-align:center;box-shadow:var(--shadow);}
  .fc-front{background:linear-gradient(135deg,#3b6ce0,#6d8df0);color:#fff;}
  .fc-back{background:linear-gradient(135deg,#0e9f56,#34c97e);color:#fff;transform:rotateY(180deg);}
  .fc-w{font-size:1.5rem;font-weight:800;}
