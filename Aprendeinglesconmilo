/* Parte un texto largo en trozos cortos (Google TTS corta a ~200 caracteres) */
function splitChunks(q){
  var parts=q.match(/[^.!?]+[.!?]*/g)||[q];
  var chunks=[],cur='';
  parts.forEach(function(p){
    p=p.trim(); if(!p) return;
    if((cur+' '+p).trim().length>180){
      if(cur){chunks.push(cur.trim());cur='';}
      if(p.length>180){
        var words=p.split(' '),c='';
        words.forEach(function(w){ if((c+' '+w).trim().length>180){if(c)chunks.push(c.trim());c=w;} else c=(c+' '+w).trim(); });
        if(c)cur=c;
      } else cur=p;
    } else cur=(cur+' '+p).trim();
  });
  if(cur)chunks.push(cur.trim());
  return chunks.length?chunks:[q];
}
