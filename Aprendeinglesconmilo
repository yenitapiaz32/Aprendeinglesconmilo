  vocab:[
    {w:"mejorar",es:"to improve",syn:"progresar, avanzar",ex:["Quiero mejorar mi español. | I want to improve my Spanish.","Ella ha mejorado mucho. | She has improved a lot.","La práctica mejora todo. | Practice improves everything.","¿Cómo puedo mejorar? | How can I improve?","Tu pronunciación ha mejorado. | Your pronunciation has improved."]},
    {w:"en realidad",es:"actually / in reality",syn:"de hecho, realmente",ex:["En realidad, no lo sé. | Actually, I don't know.","En realidad es más fácil. | It's actually easier.","En realidad, tienes razón. | Actually, you're right.","No lo hice, en realidad. | I actually didn't do it.","En realidad, es cierto. | Actually, that's true."]},
    {w:"sin embargo",es:"however / nevertheless",syn:"no obstante, pero",ex:["Es difícil; sin embargo, lo intentaré. | It's hard; however, I'll try.","Sin embargo, los precios subieron. | However, prices went up.","Estoy de acuerdo. Sin embargo... | I agree. However...","Sin embargo, continuamos. | Nevertheless, we continued.","Es caro; sin embargo, vale la pena. | It's expensive; however, it's worth it."]},
    {w:"tener ganas de",es:"to feel like / to look forward to",syn:"querer, desear",ex:["Tengo muchas ganas de verte. | I really look forward to seeing you.","Tengo ganas de comer pizza. | I feel like eating pizza.","¿Tienes ganas de salir? | Do you feel like going out?","No tengo ganas de estudiar. | I don't feel like studying.","Ella tiene ganas de viajar. | She's looking forward to traveling."]},
    {w:"estar al tanto",es:"to be up to date / to be aware",syn:"saber, conocer",ex:["Estoy al tanto de la situación. | I'm aware of the situation.","¿Estás al tanto? | Are you up to date?","Ponme al tanto. | Fill me in.","No estaba al tanto. | I wasn't aware.","Hay que estar al tanto. | You need to stay informed."]}
