C1:{
  cando:"I can use Spanish with near-native flexibility, catch nuance and humor, and write formally or casually with precision.",
  tenses:[
    {n:"Subjuntivo imperfecto",form:"-AR: habl-ara/-aras/-ara/-áramos/-aran · -ER/-IR: com-iera/-ieras/-iera/-iéramos/-ieran",use:"Si clauses (type 2 & 3), after past expressions of desire/doubt/emotion.",ex:["Si tuviera tiempo, estudiaría más. | If I had time, I would study more.","Quería que vinieras. | I wanted you to come.","Si lo hubiera sabido, habría llamado. | If I had known, I would have called.","Como si fuera fácil. | As if it were easy.","Ojalá pudiera quedarme. | I wish I could stay."]},
    {n:"Condicional compuesto (conditional perfect)",form:"habría/habrías/habría/habríamos/habrían + past participle",use:"What would have happened.",ex:["Habría llamado, pero no tenía tu número. | I would have called, but I didn't have your number.","Ella habría venido si hubiera podido. | She would have come if she could have.","¿Qué habrías hecho tú? | What would you have done?","Habríamos llegado antes. | We would have arrived sooner.","No lo habría creído. | I wouldn't have believed it."]},
    {n:"Futuro perfecto",form:"habré/habrás/habrá/habremos/habrán + past participle",use:"What will have happened by a future point.",ex:["Para junio, habré terminado el curso. | By June, I will have finished the course.","Ella ya habrá llegado para las 5. | She will have arrived by 5.","¿Habrás terminado? | Will you have finished?","Para 2030 habremos cambiado mucho. | By 2030 we will have changed a lot.","Lo habrán resuelto ya. | They will have resolved it already."]}
  ],
  grammar:[
    {t:"Oraciones condicionales (Si clauses — all types)",form:"Type 1 (possible): si + presente + futuro · Type 2 (hypothetical): si + imperfecto subj + condicional · Type 3 (past hypothetical): si + pluscuamperfecto subj + condicional compuesto",ex:["Si estudias, aprobarás. (Type 1) | If you study, you will pass.","Si tuviera dinero, viajaría. (Type 2) | If I had money, I would travel.","Si hubiera estudiado, habría aprobado. (Type 3) | If I had studied, I would have passed.","Si fuera más joven, correría más. | If I were younger, I would run more.","Si lo hubiera sabido antes... | If I had known before..."]},
    {t:"Conectores formales",form:"no obstante, sin embargo, por lo tanto, de ahí que, puesto que, dado que",ex:["Puesto que no hay evidencia, lo descartamos. | Since there's no evidence, we discard it.","Dado que es tarde, nos vamos. | Given that it's late, we're leaving.","De ahí que sea importante. | Hence why it's important.","Por lo tanto, concluimos que... | Therefore, we conclude that...","No obstante lo dicho, procederemos. | Notwithstanding what was said, we will proceed."]},
    {t:"Subjuntivo en cláusulas relativas",form:"buscar/necesitar/querer algo que + subjuntivo",ex:["Busco a alguien que sepa cocinar. | I'm looking for someone who knows how to cook.","No hay nadie que pueda ayudar. | There's no one who can help.","¿Conoces a alguien que hable chino? | Do you know anyone who speaks Chinese?","Necesito una solución que funcione. | I need a solution that works.","Quiero un trabajo que me guste. | I want a job that I like."]},
    {t:"Nominalización (formal writing)",form:"verb/adj → noun phrase",ex:["la llegada de = the arrival of (llegar)","el aumento de precios = the rise in prices (aumentar)","la implementación del plan = the implementation of the plan","la reducción de costos = the cost reduction","el fracaso del proyecto = the failure of the project"]}
  ],
  vocab:[
    {w:"socavar",es:"to undermine",syn:"debilitar, minar",ex:["Esto socava la confianza. | This undermines trust.","No la menosprecies; la socavas. | Don't belittle her; you're undermining her.","El escándalo socavó su reputación. | The scandal undermined his reputation.","Eso socava el plan. | That undermines the plan.","La corrupción socava las instituciones. | Corruption undermines institutions."]},
    {w:"matizado/a",es:"nuanced",syn:"con matices, sutil",ex:["Una opinión matizada. | A nuanced opinion.","Su argumento es muy matizado. | Her argument is very nuanced.","Un enfoque más matizado. | A more nuanced approach.","La realidad es más matizada. | Reality is more nuanced.","Un debate matizado. | A nuanced debate."]},
    {w:"abogar por",es:"to advocate for",syn:"defender, apoyar",ex:["Abogo por la educación gratuita. | I advocate for free education.","Ella aboga por los derechos humanos. | She advocates for human rights.","El abogado abogó por su cliente. | The lawyer advocated for his client.","Abogar por el cambio es necesario. | Advocating for change is necessary.","¿Por qué abogan? | What are they advocating for?"]},
    {w:"en términos generales",es:"broadly speaking / in general terms",syn:"por lo general, en general",ex:["En términos generales, estoy de acuerdo. | Broadly speaking, I agree.","En términos generales, funciona bien. | In general terms, it works well.","En términos generales, el plan es sólido. | Broadly speaking, the plan is solid.","En términos generales, hubo éxito. | Generally speaking, there was success.","En términos generales, es correcto. | Broadly, it is correct."]}
  ],
  idioms:[["Andarse con rodeos","To beat around the bush","¡Deja de andarte con rodeos! | Stop beating around the bush!"],["Tirar la toalla","To throw in the towel","No tires la toalla. | Don't throw in the towel."],["No hay mal que por bien no venga","Every cloud has a silver lining","Perdí el trabajo, pero encontré uno mejor. | I lost the job, but found a better one."],["Ponerse en los zapatos de","To put yourself in someone's shoes","Ponte en mis zapatos. | Put yourself in my shoes."],["A grandes rasgos","Broadly speaking / in outline","A grandes rasgos, el plan funciona. | Broadly speaking, the plan works."]],
  reading:{text:["La idea de que solo el talento determina el éxito es, en el mejor de los casos, una verdad a medias. Si bien la habilidad natural brinda una ventaja inicial, es la capacidad de perseverar ante el fracaso lo que, en términos generales, distingue a los grandes triunfadores. La investigación sugiere que la determinación —combinación de pasión y esfuerzo sostenido— suele pesar más que la inteligencia bruta. Sin disciplina, incluso los más dotados tienden a estancarse."],tr:"The idea that talent alone determines success is, at best, a half-truth. While natural ability provides an initial advantage, it is broadly speaking the capacity to persevere through failure that distinguishes high achievers. Research suggests that grit — a combination of passion and sustained effort — often outweighs raw intelligence. Without discipline, even the most gifted tend to plateau.",q:["¿Qué se califica como 'verdad a medias'? | What is called a half-truth?","¿Qué brinda la habilidad natural? | What does natural ability provide?","¿Qué distingue a los grandes triunfadores? | What distinguishes high achievers?","¿Qué es la 'determinación' según el texto? | What is 'grit' according to the text?","¿Qué les pasa a los dotados sin disciplina? | What happens to the gifted without discipline?"]},
  listening:[["El País / Cadena SER podcasts","https://www.youtube.com/results?search_query=podcast+espanol+nativo+avanzado"],["Spanish TED talks","https://www.youtube.com/results?search_query=ted+talk+en+espanol+subtitulos"],["Spanish stand-up comedy","https://www.youtube.com/results?search_query=monólogo+humor+español"],["Late night TV España","https://www.youtube.com/results?search_query=programa+late+night+españa+entrevista"],["Debate político en español","https://www.youtube.com/results?search_query=debate+político+español+avanzado"]],
  writing:["Write a formal opinion essay intro with a cleft sentence and a nuanced caveat.","Argue a controversial point, then give the counterargument.","Summarize a complex idea using formal connectors (no obstante, por lo tanto).","Write about a past regret using si + hubiera + habría (Type 3 conditional).","Rewrite 3 sentences using nominalization (verb phrase → noun phrase)."],
  speaking:["Give a 3-minute talk on a complex topic with intro and conclusion.","Practice hedging: 'En términos generales...', 'Cabe mencionar que...', 'A grandes rasgos...'.","React to a news story with irony and opinion.","Defend a position, then argue the opposite (devil's advocate).","Explain an abstract concept without using simple words."],
  quiz:[["Si tuviera más tiempo, ___ más. (estudiar)","estudiaría",["estudiaba","estudiará","estudiare"]],["___ más, habría aprobado. (si/estudiar - Type 3)","Si hubiera estudiado",["Si hubiera estudiaba","Si estudiaría","Si habría estudiado"]],["Busco a alguien que ___ (saber) cocinar.","sepa",["sabe","sabrá","supo"]],["___ la tarde, nos fuimos. (dado que)","Dado que era",["Dado que fue","Puesto que era","De ahí que"]],["Para junio, ___ (haber + terminar) el curso.","habré terminado",["había terminado","habré terminando","terminaré"]],["La ___ del plan fue un éxito. (implementar)","implementación",["implementación","implementar","implementado"]]],
