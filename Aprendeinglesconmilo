  cando:"I can express complex ideas, discuss hypotheticals, use the subjunctive fluently, and understand most TV shows.",
  tenses:[
    {n:"Condicional simple (conditional)",form:"-ía/-ías/-ía/-íamos/-ían (all verbs)",use:"Hypothetical situations; polite requests.",ex:["Me gustaría visitar España. | I would like to visit Spain.","¿Podrías ayudarme? | Could you help me?","Si tuviera dinero, viajaría. | If I had money, I would travel.","Sería genial. | That would be great.","¿Qué harías tú? | What would you do?"]},
    {n:"Subjuntivo presente (full use)",form:"hablar→hable, comer→coma, vivir→viva",use:"Emotion, doubt, desire, impersonal expressions, and future relative clauses.",ex:["Espero que llegues pronto. | I hope you arrive soon.","Dudo que sea verdad. | I doubt it's true.","Es necesario que estudies. | It's necessary that you study.","Busco un apartamento que sea barato. | I'm looking for an apartment that is cheap.","Cuando llegues, llámame. | When you arrive, call me."]},
    {n:"Pluscuamperfecto (past perfect)",form:"había/habías/había/habíamos/habían + past participle",use:"The past before another past.",ex:["Cuando llegué, ella ya había salido. | When I arrived, she had already left.","Nunca había comido sushi. | I had never eaten sushi.","Habían terminado antes de las 5. | They had finished before 5.","Ya había llovido cuando salimos. | It had already rained when we left.","Él había estudiado toda la noche. | He had studied all night."]}
