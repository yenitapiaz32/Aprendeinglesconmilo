  IH:{rx:40,ry:15,round:.1,teeth:'top',tongue:'mid',lbl:'ɪ (ship)'},
  OW:{rx:24,ry:26,round:1,teeth:'none',tongue:'low',lbl:'o'},
  UW:{rx:16,ry:18,round:1,teeth:'none',tongue:'low',lbl:'uː'},
  UH:{rx:32,ry:20,round:.3,teeth:'top',tongue:'mid',lbl:'ʌ'},
