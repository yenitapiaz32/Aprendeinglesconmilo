const SPEAK_PHRASES={
  A1:["Hello, how are you?","My name is Yenifer.","I live in Colombia.","I like coffee.","Nice to meet you.","I have a big family."],
  A2:["What did you do yesterday?","I'm going to travel next month.","Can you help me, please?","I went to the park.","This is cheaper than that."],
  B1:["I've been learning English for a while.","I was cooking when she called.","If it rains, I'll stay home.","To be honest, I'm not sure.","I used to play the piano."],
  B2:["If I were you, I would rest.","I've been studying all day.","The car was repaired yesterday.","I'd rather not talk about it.","That's a good point, but I disagree."],
  C1:["By 2030, I will have graduated.","Never have I seen such a thing.","What I need is more time.","I'm inclined to think that it works.","To put it bluntly, it's not enough."]
};
let speakLevel=store.get('curLevel','A1'), recog=null, speakIdx=0;
function speakSupported(){return ('webkitSpeechRecognition' in window)||('SpeechRecognition' in window);}
function normWords(s){return s.toLowerCase().replace(/[^a-z0-9'\s]/g,'').split(/\s+/).filter(Boolean);}
function scoreSpeech(target,said){
  const t=normWords(target), s=new Set(normWords(said));
  if(!t.length) return 0;
  let hit=0; t.forEach(w=>{if(s.has(w))hit++;});
  return Math.round(hit/t.length*100);
}
function renderSpeak(){
  const el=document.getElementById('speakContent');
  const list=SPEAK_PHRASES[speakLevel]||SPEAK_PHRASES.A1;
  const phrase=list[speakIdx%list.length];
  let h='';
  if(!speakSupported()){
    h+='<div class="skillbox"><h4>🎤 Tu navegador no soporta micrófono aquí</h4><p class="note">Speak Now necesita Chrome o Edge (en Android o computadora). Mientras tanto, puedes escuchar la frase y repetirla en voz alta.</p></div>';
  }
  h+='<div class="subnav" style="margin-bottom:12px;">'+LEVELS.map(L=>'<button class="'+(L===speakLevel?'active':'')+'" onclick="speakLevel=\''+L+'\';speakIdx=0;renderSpeak();">'+meta[L].e+' '+L+'</button>').join('')+'</div>';
  h+='<div class="skillbox" style="text-align:center;">'
    +'<p style="font-size:1.25rem;font-weight:800;font-family:\'Baloo 2\',sans-serif;margin-bottom:6px;">'+phrase+'</p>'
    +'<button class="btn" onclick="speak(\''+phrase.replace(/'/g,"\\'")+'\')">🔊 Escuchar</button> '
    +'<button class="btn primary" id="micBtn" onclick="startListen(\''+phrase.replace(/'/g,"\\'")+'\')">🎤 Hablar</button>'
    +'<div id="speakFb" style="margin-top:12px;font-weight:700;min-height:24px;"></div>'
    +'<button class="btn" style="margin-top:8px;" onclick="speakIdx++;renderSpeak();">Siguiente frase →</button>'
    +'</div>';
  h+='<p class="note">💡 Consejo de Milo: exagera un poco el sonido. Apunta a la R fuerte y la flap T (water → "warer").</p>';
  el.innerHTML=h;
}
function startListen(target){
  if(!speakSupported()){document.getElementById('speakFb').innerHTML='<span style="color:var(--red)">Usa Chrome o Edge para hablar.</span>';return;}
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  recog=new SR(); recog.lang='en-US'; recog.interimResults=false; recog.maxAlternatives=3;
  const fb=document.getElementById('speakFb'), btn=document.getElementById('micBtn');
  fb.innerHTML='🎙️ Escuchando… di la frase.'; btn.textContent='● Grabando…';
  recog.onresult=function(e){
    let best=0, saidText='';
    for(let i=0;i<e.results[0].length;i++){const alt=e.results[0][i].transcript;const sc=scoreSpeech(target,alt);if(sc>=best){best=sc;saidText=alt;}}
    btn.textContent='🎤 Hablar';
    let emoji=best>=85?'🏆':best>=60?'👍':'💪', msg=best>=85?'¡Excelente pronunciación!':best>=60?'¡Bien! Sigue practicando.':'Casi. Inténtalo otra vez.';
    fb.innerHTML='<div style="font-size:1.4rem;">'+emoji+' '+best+'%</div><div style="font-weight:400;color:var(--muted);font-size:.86rem;">Escuché: "'+saidText+'"</div><div style="margin-top:4px;">'+msg+'</div>';
    if(best>=60){addXP(10);beep('good');if(best>=85)confetti();markDaily('speaking');}else{beep('bad');}
  };
  recog.onerror=function(){btn.textContent='🎤 Hablar';fb.innerHTML='<span style="color:var(--red)">No se pudo escuchar. Revisa el permiso del micrófono.</span>';};
  recog.onend=function(){if(btn.textContent==='● Grabando…')btn.textContent='🎤 Hablar';};
  try{recog.start();}catch(e){}
}

