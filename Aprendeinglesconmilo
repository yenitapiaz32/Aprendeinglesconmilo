function applyViseme(v){
  var P=VIS[v]||VIS.rest;
  var cy=170;
  var inner=document.getElementById('mInner'), lips=document.getElementById('mLips'),
      tt=document.getElementById('mTeethTop'), tb=document.getElementById('mTeethBot'),
      tg=document.getElementById('mTongue'), lbl=document.getElementById('mthLbl');
  if(!inner)return;
  function set(el,a,val){try{el.setAttribute(a,val);}catch(e){}}
  set(inner,'rx',P.rx); set(inner,'ry',P.ry);
  var lrx=Math.max(14,P.rx+12-P.round*20), lry=P.ry+11+P.round*7;
