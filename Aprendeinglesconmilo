  idioms:[["Meter la pata","To put your foot in it","Metí la pata con ese comentario. | I put my foot in it with that comment."],["Estar en las nubes","To have your head in the clouds","¡Estás en las nubes! | You have your head in the clouds!"],["Ponerse las pilas","To get your act together","¡Ponte las pilas! | Get your act together!"],["Dar en el clavo","To hit the nail on the head","¡Diste en el clavo! | You hit the nail on the head!"],["A todo correr","At full speed / in a rush","Llegué a todo correr. | I arrived in a rush."],["Echar de menos","To miss (someone/something)","Echo de menos a mi familia. | I miss my family."]],
  dialog:[
    {t:"✈️ At the airport",lines:[["Agente","Buenos días. ¿Su pasaporte, por favor?","Good morning. Your passport, please?"],["You","Aquí tiene.","Here it is."],["Agente","¿Va a facturar maletas?","Are you checking any bags?"],["You","Solo una maleta.","Just one suitcase."],["Agente","De acuerdo. Su puerta es la B12. ¡Buen vuelo!","OK. Your gate is B12. Have a nice flight!"]]}
  ],
  reading:{text:["Llevo cerca de un año aprendiendo español. Al principio, todo me parecía muy difícil, y casi me rendí. Sin embargo, seguí practicando y ahora puedo mantener conversaciones básicas. La clave fue no tener miedo de cometer errores. Si quieres aprender un idioma nuevo, tienes que ser paciente contigo mismo y seguir adelante, aunque sea difícil."],tr:"I've been learning Spanish for about a year. At first, everything seemed very difficult, and I almost gave up. However, I kept practicing and now I can hold basic conversations. The key was not being afraid of making mistakes. If you want to learn a new language, you have to be patient with yourself and keep going, even when it's hard.",q:["¿Cuánto tiempo lleva aprendiendo español? | How long has he been learning Spanish?","¿Cómo se sentía al principio? | How did it seem at first?","¿Por qué casi se rindió? | Why did he almost give up?","¿Qué puede hacer ahora? | What can he do now?","¿Cuál fue la clave? | What was the key?"]},
  listening:[["Dreaming Spanish intermediate","https://www.youtube.com/results?search_query=dreaming+spanish+intermediate"],["Spanish B1 podcast","https://www.youtube.com/results?search_query=spanish+b1+podcast+listening"],["Pretérito vs imperfecto","https://www.youtube.com/results?search_query=preterite+vs+imperfect+spanish+lesson"],["Travel Spanish conversations","https://www.youtube.com/results?search_query=travel+spanish+conversation+intermediate"],["Coffee Break Spanish","https://www.youtube.com/results?search_query=coffee+break+spanish+b1"]],
  writing:["Write about a childhood habit using the imperfecto.","Give your opinion on social media (sin embargo, porque).","Describe a goal and how you'll achieve it (futuro).","Write about a recent experience (pretérito perfecto).","Use the subjunctive: 'Espero que...', 'Quiero que...'."],
  speaking:["Talk for 2 minutes about a trip or experience.","Give your opinion on a topic (creo que, en mi opinión).","4-3-2 method: tell the same story in 4, 3, then 2 minutes.","Talk about what you used to do as a child (imperfecto).","Describe what you've achieved this year (pretérito perfecto)."],
